<!-- ── Floating AI Chat ──────────────────────────────────────────────────────── -->

<div id="ai-backdrop" onclick="closeAiFloat()" style="display:none;position:fixed;inset:0;z-index:90;"></div>

<div id="ai-float-panel" class="ai-float-panel hidden">

  <!-- Header -->
  <div class="ai-float-header">
    <div style="display:flex;align-items:center;gap:8px;">
      <span class="ai-badge" style="flex-shrink:0;">AI</span>
      <div>
        <div style="font-size:13px;font-weight:600;color:#fff;">HydroScope AI</div>
        <div id="ai-float-context-label" style="font-size:10px;color:#475569;margin-top:1px;"></div>
      </div>
    </div>
    <div style="display:flex;align-items:center;gap:6px;">
      <button id="ai-clear-btn" onclick="clearChat()" title="Clear conversation" style="background:none;border:none;color:#475569;cursor:pointer;font-size:11px;padding:3px 6px;border-radius:4px;transition:color 0.15s;" onmouseover="this.style.color='#94a3b8'" onmouseout="this.style.color='#475569'">↺ clear</button>
      <button onclick="closeAiFloat()" style="background:none;border:none;color:#64748b;cursor:pointer;font-size:18px;line-height:1;padding:4px;" title="Close">×</button>
    </div>
  </div>

  <!-- Mode selector -->
  <div id="ai-mode-bar" style="display:flex;align-items:center;gap:4px;padding:6px 12px;border-bottom:1px solid #1e293b;flex-shrink:0;">
    <button class="ai-mode-btn" data-mode="general"   onclick="setMode('general')">General</button>
    <button class="ai-mode-btn" data-mode="wiki"      onclick="setMode('wiki')">Guide</button>
    <button class="ai-mode-btn" data-mode="analyst"   onclick="setMode('analyst')">Analyst</button>
    <button class="ai-mode-btn" data-mode="research"  onclick="setMode('research')">Research</button>
    <span id="ai-mode-hint" style="margin-left:auto;font-size:9px;color:#334155;font-style:italic;"></span>
  </div>

  <!-- Message history -->
  <div id="ai-float-history" class="ai-float-history">
    <div id="ai-float-empty" style="display:flex;align-items:center;justify-content:center;height:100%;flex-direction:column;gap:10px;color:#334155;">
      <svg style="width:28px;height:28px;opacity:0.35;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
      <span style="font-size:11px;text-align:center;line-height:1.6;color:#334155;">Ask about conditions, data, or<br>how to use this dashboard</span>
    </div>
  </div>

  <!-- Input -->
  <div class="ai-float-input-area">
    <textarea
      id="ai-float-input"
      class="ai-float-textarea"
      placeholder="Ask a question… (Ctrl+Enter to send)"
      rows="2"
      onkeydown="handleFloatKey(event)"
      oninput="autoResizeFloat(this)"
    ></textarea>
    <div style="display:flex;justify-content:space-between;align-items:center;margin-top:8px;">
      <span id="ai-float-status" style="font-size:11px;color:#475569;"></span>
      <button id="ai-float-submit" onclick="submitFloat()" class="btn-primary" style="padding:6px 16px;font-size:12px;">Send</button>
    </div>
  </div>
</div>

<!-- Fixed top-right profile button -->
<button id="profile-topbtn" onclick="profileSO.open()" title="Open profile"
  style="position:fixed;top:13px;right:16px;z-index:80;
         width:34px;height:34px;border-radius:8px;background:#0369a1;
         border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;
         font-size:12px;font-weight:700;color:#fff;letter-spacing:.02em;
         box-shadow:0 2px 10px rgba(3,105,161,0.45);
         transition:background 0.15s,transform 0.1s,box-shadow 0.15s;"
  onmouseover="this.style.background='#0ea5e9';this.style.boxShadow='0 4px 16px rgba(14,165,233,0.5)';"
  onmouseout="this.style.background='#0369a1';this.style.boxShadow='0 2px 10px rgba(3,105,161,0.45)';">
  <span id="profile-topbtn-initials">
    <svg style="width:17px;height:17px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
  </span>
</button>

<!-- Trigger button -->
<button id="ai-float-btn" onclick="toggleAiFloat(event)" title="Ask AI" aria-label="Open AI assistant">
  <svg style="width:22px;height:22px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
</button>

<style>
#ai-float-btn {
  position:fixed;bottom:24px;right:24px;z-index:95;
  width:48px;height:48px;border-radius:50%;
  background:#0284c7;border:none;cursor:pointer;color:#fff;
  display:flex;align-items:center;justify-content:center;
  box-shadow:0 4px 20px rgba(2,132,199,0.45);
  transition:transform 0.15s,box-shadow 0.15s;
}
#ai-float-btn:hover { transform:scale(1.08);box-shadow:0 6px 28px rgba(2,132,199,0.55); }
#ai-float-btn.open  { background:#0369a1;transform:rotate(15deg); }

.ai-float-panel {
  position:fixed;bottom:84px;right:24px;z-index:91;
  width:380px;max-height:580px;
  background:#0f172a;border:1px solid #1e293b;
  border-radius:16px;box-shadow:0 12px 50px rgba(0,0,0,0.6);
  display:flex;flex-direction:column;overflow:hidden;
  transform-origin:bottom right;
  transition:opacity 0.15s,transform 0.15s;
}
.ai-float-panel.hidden { opacity:0;transform:scale(0.94) translateY(8px);pointer-events:none; }

.ai-float-header {
  display:flex;align-items:center;justify-content:space-between;
  padding:12px 14px;border-bottom:1px solid #1e293b;flex-shrink:0;
}
.ai-float-history {
  flex:1;overflow-y:auto;padding:12px 14px;
  display:flex;flex-direction:column;gap:10px;min-height:160px;
}
.ai-float-input-area {
  padding:10px 14px 12px;border-top:1px solid #1e293b;flex-shrink:0;
}
.ai-float-textarea {
  width:100%;background:#1e293b;border:1px solid #334155;
  border-radius:8px;padding:8px 10px;font-size:13px;color:#f1f5f9;
  resize:none;outline:none;font-family:'Inter',sans-serif;line-height:1.5;
  box-sizing:border-box;max-height:120px;overflow-y:auto;
  transition:border-color 0.15s;
}
.ai-float-textarea:focus { border-color:#0ea5e9; }
.ai-float-textarea::placeholder { color:#475569; }

/* Mode buttons */
.ai-mode-btn {
  font-size:10px;font-weight:600;padding:3px 9px;border-radius:4px;
  border:1px solid #1e293b;background:transparent;color:#475569;
  cursor:pointer;transition:all 0.12s;letter-spacing:.04em;text-transform:uppercase;
}
.ai-mode-btn:hover { border-color:#334155;color:#64748b; }
.ai-mode-btn.active { background:#0369a1;border-color:#0369a1;color:#fff; }
.ai-mode-btn[data-mode="wiki"].active     { background:#7c3aed;border-color:#7c3aed; }
.ai-mode-btn[data-mode="analyst"].active  { background:#0d9488;border-color:#0d9488; }
.ai-mode-btn[data-mode="research"].active { background:#b45309;border-color:#b45309; }

/* Message bubbles */
.ai-msg-user {
  align-self:flex-end;max-width:85%;
  background:#0369a1;color:#e0f2fe;border-radius:12px 12px 4px 12px;
  padding:8px 12px;font-size:13px;line-height:1.5;
}
.ai-msg-ai {
  align-self:flex-start;max-width:92%;
  background:#1e293b;color:#cbd5e1;border-radius:12px 12px 12px 4px;
  padding:8px 12px;font-size:13px;line-height:1.6;white-space:pre-wrap;
}
.ai-msg-label {
  display:block;font-size:9px;font-weight:700;letter-spacing:.07em;text-transform:uppercase;
  margin-bottom:5px;line-height:1;
}
.ai-msg-label.mode-general  { color:#38bdf8; }
.ai-msg-label.mode-wiki     { color:#a78bfa; }
.ai-msg-label.mode-analyst  { color:#34d399; }
.ai-msg-label.mode-research { color:#fb923c; }
.ai-msg-clarify {
  align-self:flex-start;max-width:92%;
  background:rgba(14,165,233,0.08);border:1px solid rgba(14,165,233,0.2);
  border-radius:12px;padding:8px 12px;font-size:12px;color:#7dd3fc;line-height:1.6;
  font-style:italic;
}
.ai-msg-loading {
  align-self:flex-start;
  display:flex;align-items:center;gap:6px;
  font-size:12px;color:#475569;padding:6px 0;
}

/* Light mode */
body.light .ai-float-panel { background:#fff;border-color:#e2e8f0;box-shadow:0 12px 50px rgba(0,0,0,0.15); }
body.light .ai-float-header,
body.light .ai-float-input-area,
body.light #ai-mode-bar      { border-color:#e2e8f0; }
body.light .ai-float-textarea { background:#f8fafc;border-color:#cbd5e1;color:#0f172a; }
body.light .ai-float-textarea::placeholder { color:#94a3b8; }
body.light .ai-msg-ai         { background:#f1f5f9;color:#334155; }
body.light #ai-float-empty    { color:#94a3b8; }
body.light .ai-mode-btn       { border-color:#e2e8f0;color:#94a3b8; }
body.light .ai-mode-btn:hover { border-color:#cbd5e1;color:#64748b; }
</style>

<script>
(function() {
  // ── Session storage keys ────────────────────────────────────────────────────
  var SK_HISTORY = 'hs_chat_history';
  var SK_MODE    = 'hs_chat_mode';

  var _open    = false;
  var _loading = false;
  var _mode    = 'general';
  // Conversation history: [{role:'user'|'model', text:'...'}] — API format
  var _history = [];
  // Display entries: [{type:'user'|'ai'|'clarify'|'mode-switch', text, mode, label}]
  var _display = [];

  var _page = (typeof activePage !== 'undefined' ? activePage : null)
    || document.body.getAttribute('data-page') || 'unknown';

  // ── Session persistence ─────────────────────────────────────────────────────
  function saveSession() {
    try {
      sessionStorage.setItem(SK_HISTORY, JSON.stringify({ history: _history, display: _display }));
      sessionStorage.setItem(SK_MODE,    _mode);
    } catch(_) {}
  }

  function loadSession() {
    try {
      var m = sessionStorage.getItem(SK_MODE);
      if (m) _mode = m;
      var raw = sessionStorage.getItem(SK_HISTORY);
      if (raw) {
        var data = JSON.parse(raw);
        _history = data.history || [];
        _display = data.display || [];
      }
    } catch(_) {}
  }

  // ── Mode management ─────────────────────────────────────────────────────────
  var MODE_LABELS = { general:'General', wiki:'Guide', analyst:'Analyst', research:'Research' };
  var MODE_HINTS  = {
    general:  'General answers, explains concepts',
    wiki:     'About this app — pages, colors, features',
    analyst:  'Live data, numbers & trends',
    research: 'Domain knowledge + data, sources cited',
  };

  window.setMode = function(m) {
    _mode = m;
    document.querySelectorAll('.ai-mode-btn').forEach(function(b) {
      b.classList.toggle('active', b.getAttribute('data-mode') === m);
    });
    document.getElementById('ai-mode-hint').textContent = MODE_HINTS[m] || '';
    saveSession();
  };

  function applyModeButtons() {
    document.querySelectorAll('.ai-mode-btn').forEach(function(b) {
      b.classList.toggle('active', b.getAttribute('data-mode') === _mode);
    });
    document.getElementById('ai-mode-hint').textContent = MODE_HINTS[_mode] || '';
  }

  // ── Clear ───────────────────────────────────────────────────────────────────
  window.clearChat = function() {
    _history = [];
    _display = [];
    saveSession();
    var histEl = document.getElementById('ai-float-history');
    histEl.innerHTML = '';
    var empty = document.createElement('div');
    empty.id = 'ai-float-empty';
    empty.style.cssText = 'display:flex;align-items:center;justify-content:center;height:100%;flex-direction:column;gap:10px;color:#334155;';
    empty.innerHTML = '<svg style="width:28px;height:28px;opacity:0.35;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg><span style="font-size:11px;text-align:center;line-height:1.6;color:#334155;">Ask about conditions, data, or<br>how to use this dashboard</span>';
    histEl.appendChild(empty);
  };

  // ── Render display history ──────────────────────────────────────────────────
  function renderHistory() {
    var histEl = document.getElementById('ai-float-history');
    if (!histEl) return;
    histEl.innerHTML = '';
    if (!_display.length) {
      var empty = document.createElement('div');
      empty.id = 'ai-float-empty';
      empty.style.cssText = 'display:flex;align-items:center;justify-content:center;height:100%;flex-direction:column;gap:10px;color:#334155;';
      empty.innerHTML = '<svg style="width:28px;height:28px;opacity:0.35;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg><span style="font-size:11px;text-align:center;line-height:1.6;color:#334155;">Ask about conditions, data, or<br>how to use this dashboard</span>';
      histEl.appendChild(empty);
      return;
    }
    _display.forEach(function(entry) { appendDisplayEntry(histEl, entry); });
    histEl.scrollTop = histEl.scrollHeight;
  }

  function appendDisplayEntry(histEl, entry) {
    var el;
    if (entry.type === 'user') {
      el = document.createElement('div');
      el.className = 'ai-msg-user';
      el.textContent = entry.text;
    } else if (entry.type === 'ai') {
      el = document.createElement('div');
      el.className = 'ai-msg-ai';
      var lbl = document.createElement('div');
      lbl.className = 'ai-msg-label mode-' + (entry.mode || 'general');
      lbl.textContent = (MODE_LABELS[entry.mode] || 'AI') + (entry.dataIncluded ? ' · live data' : '');
      var txt = document.createElement('div');
      txt.textContent = entry.text;
      el.appendChild(lbl);
      el.appendChild(txt);
    } else if (entry.type === 'clarify') {
      el = document.createElement('div');
      el.className = 'ai-msg-clarify';
      el.textContent = '⟳ ' + entry.text;
    }
    // mode-switch entries are intentionally dropped — the active mode button shows it
    if (el) histEl.appendChild(el);
  }

  // ── Open / close ────────────────────────────────────────────────────────────
  function updateContextLabel() {
    var label = document.getElementById('ai-float-context-label');
    if (!label) return;
    var parts = [];
    if (_page && _page !== 'unknown') parts.push(_page.replace(/-/g,' ').replace('_',' '));
    var siteEl  = document.getElementById('siteSelect');
    var paramEl = document.getElementById('paramSelect');
    if (siteEl  && siteEl.selectedOptions[0])  parts.push(siteEl.selectedOptions[0].textContent.split('—')[0].trim());
    if (paramEl && paramEl.selectedOptions[0]) parts.push(paramEl.selectedOptions[0].textContent.replace('★','').trim());
    label.textContent = parts.length ? parts.join(' · ') : '';
  }

  window.toggleAiFloat = function(e) {
    if (e) e.stopPropagation();
    _open ? closeAiFloat() : openAiFloat();
  };

  window.openAiFloat = function() {
    _open = true;
    document.getElementById('ai-float-panel').classList.remove('hidden');
    document.getElementById('ai-backdrop').style.display = 'block';
    document.getElementById('ai-float-btn').classList.add('open');
    updateContextLabel();
    applyModeButtons();
    renderHistory();
    setTimeout(function() { document.getElementById('ai-float-input').focus(); }, 120);
  };

  window.closeAiFloat = function() {
    _open = false;
    document.getElementById('ai-float-panel').classList.add('hidden');
    document.getElementById('ai-backdrop').style.display = 'none';
    document.getElementById('ai-float-btn').classList.remove('open');
  };

  // ── Input handlers ──────────────────────────────────────────────────────────
  window.handleFloatKey = function(e) {
    if (e.key === 'Enter' && (e.ctrlKey || e.metaKey)) { e.preventDefault(); submitFloat(); }
  };

  window.autoResizeFloat = function(el) {
    el.style.height = 'auto';
    el.style.height = Math.min(el.scrollHeight, 120) + 'px';
  };

  // ── Submit ───────────────────────────────────────────────────────────────────
  window.submitFloat = async function() {
    if (_loading) return;
    var input = document.getElementById('ai-float-input');
    var query = input.value.trim();
    if (!query) return;

    // Auto-switch to analyst mode when query is clearly asking for metric calculations
    var _metricTerms = ['minimum','maximum',' min ',' max ','mean','average','median','variance',
      'std dev','stddev','standard deviation','range','domain','spread','skew',
      'calculate','percentile','outlier','correlation'];
    var _qLower = query.toLowerCase();
    if (_mode !== 'analyst' && _metricTerms.some(function(t) { return _qLower.includes(t); })) {
      setMode('analyst');
    }

    _loading = true;
    input.value = '';
    input.style.height = 'auto';
    document.getElementById('ai-float-submit').disabled = true;

    var histEl = document.getElementById('ai-float-history');
    var statusEl = document.getElementById('ai-float-status');

    // Remove empty state
    var emptyEl = document.getElementById('ai-float-empty');
    if (emptyEl) emptyEl.remove();

    // Render user bubble immediately
    var userEntry = { type:'user', text:query };
    _display.push(userEntry);
    appendDisplayEntry(histEl, userEntry);

    // Loading bubble — text is updated during retries
    var loadingEl = document.createElement('div');
    loadingEl.className = 'ai-msg-loading';
    loadingEl.innerHTML = '<svg class="animate-spin" style="width:12px;height:12px;color:#0ea5e9;" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/></svg><span id="ai-loading-text">Thinking…</span>';
    histEl.appendChild(loadingEl);
    histEl.scrollTop = histEl.scrollHeight;

    function setLoadingText(t) {
      var el = document.getElementById('ai-loading-text');
      if (el) el.textContent = t;
    }

    // Page context — always include current page; eagerly collect all available selectors
    var siteEl   = document.getElementById('siteSelect');
    var paramEl  = document.getElementById('paramSelect');
    var hoursEl  = document.getElementById('hoursSelect') || document.getElementById('fnHours');
    var pageCtx  = { current_page: _page };
    if (siteEl && siteEl.value) {
      pageCtx.site_id    = siteEl.value;
      pageCtx.site_name  = siteEl.selectedOptions[0] ? siteEl.selectedOptions[0].textContent.split('—')[0].trim() : siteEl.value;
      pageCtx.param_code = paramEl && paramEl.value ? paramEl.value : undefined;
      pageCtx.param_name = paramEl && paramEl.selectedOptions[0] ? paramEl.selectedOptions[0].textContent.replace('★','').trim() : null;
    }
    if (hoursEl && hoursEl.value) pageCtx.visible_hours = hoursEl.value;

    var payload = JSON.stringify({ query, mode: _mode, history: _history, page_context: pageCtx });

    // Retry up to 2 times with delay
    var MAX_ATTEMPTS = 2;
    var json = null;
    var lastErr = null;

    for (var attempt = 1; attempt <= MAX_ATTEMPTS; attempt++) {
      try {
        if (attempt > 1) {
          setLoadingText('Retrying…');
          await new Promise(function(r) { setTimeout(r, 1800); });
        }
        var resp = await fetch('/api/insights/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: payload,
        });
        if (!resp.ok) throw new Error('HTTP ' + resp.status);
        var candidate = await resp.json();

        // Backend needs more context — silently collect all requested fields and resubmit
        if (candidate.needs_context && candidate.fields && attempt === 1) {
          var enriched = JSON.parse(payload);
          if (!enriched.page_context) enriched.page_context = {};
          candidate.fields.forEach(function(f) {
            switch(f) {
              case 'current_page':
                enriched.page_context.current_page = _page;
                break;
              case 'selected_site': {
                var sel = document.getElementById('siteSelect');
                if (sel && sel.value) {
                  enriched.page_context.site_id = sel.value;
                  enriched.page_context.site_name = sel.selectedOptions[0] ? sel.selectedOptions[0].textContent.split('—')[0].trim() : sel.value;
                }
                break;
              }
              case 'selected_param': {
                var par = document.getElementById('paramSelect');
                if (par && par.value) {
                  enriched.page_context.param_code = par.value;
                  enriched.page_context.param_name = par.selectedOptions[0] ? par.selectedOptions[0].textContent.replace('★','').trim() : par.value;
                }
                break;
              }
              case 'selected_sites': {
                // Compare page stores multi-site selection in _compareSiteIds
                if (typeof _compareSiteIds !== 'undefined' && _compareSiteIds.length) {
                  enriched.page_context.site_ids = _compareSiteIds;
                }
                break;
              }
              case 'visible_hours': {
                var hoursEl = document.getElementById('hoursSelect') || document.getElementById('fnHours');
                if (hoursEl && hoursEl.value) enriched.page_context.visible_hours = hoursEl.value;
                break;
              }
            }
          });
          payload = JSON.stringify(enriched);
          throw new Error('needs_context'); // triggers retry loop with enriched payload
        }

        // Treat server error or blank response as failure worth retrying
        if (candidate.ok === false || (!candidate.blocked && !candidate.clarification && (!candidate.response || !candidate.response.trim()))) {
          throw new Error(candidate.error || 'empty response');
        }
        json = candidate;
        lastErr = null;
        break;
      } catch(e) {
        lastErr = e;
      }
    }

    loadingEl.remove();

    if (!json) {
      // All attempts failed
      var errEntry = { type:'ai', text:"Couldn't get a response — please try again.", mode: _mode };
      _display.push(errEntry);
      appendDisplayEntry(histEl, errEntry);
    } else if (json.blocked) {
      var blockedEntry = { type:'ai', text:"That's outside what I can help with here.", mode: _mode };
      _display.push(blockedEntry);
      appendDisplayEntry(histEl, blockedEntry);
    } else if (json.clarification) {
      if (json.modeChanged && json.mode) setMode(json.mode);
      var clarEntry = { type:'clarify', text: json.clarification };
      _display.push(clarEntry);
      appendDisplayEntry(histEl, clarEntry);
    } else {
      _history.push({ role:'user',  text: query });
      _history.push({ role:'model', text: json.response });
      if (_history.length > 20) _history = _history.slice(_history.length - 20);
      if (json.modeChanged && json.mode) setMode(json.mode);
      var aiEntry = { type:'ai', text: json.response, mode: json.mode || _mode, dataIncluded: json.dataIncluded };
      _display.push(aiEntry);
      appendDisplayEntry(histEl, aiEntry);
    }

    saveSession();
    histEl.scrollTop = histEl.scrollHeight;
    statusEl.textContent = '';
    _loading = false;
    document.getElementById('ai-float-submit').disabled = false;
    document.getElementById('ai-float-input').focus();
  };

  // ── Init ────────────────────────────────────────────────────────────────────
  loadSession();
  applyModeButtons();

})();
</script>

  <script src="/js/app.js"></script>
</body>
</html>

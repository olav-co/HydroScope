<%
  // Required: panelId, title
  // Optional: compact (bool) — use inline style vs full card
  var _compact = typeof compact !== 'undefined' && compact;
%>
<div id="<%= panelId %>" class="<%= _compact ? 'ai-panel' : 'ai-panel-card' %>">
  <div class="flex items-center gap-2 mb-2">
    <span class="ai-badge">AI</span>
    <span class="text-xs font-medium" style="color:#38bdf8;letter-spacing:.05em;text-transform:uppercase"><%= title || 'AI Notes' %></span>
    <div style="margin-left:auto;display:flex;align-items:center;gap:0.75rem;">
      <span class="ai-cached text-xs hidden" style="color:#64748b;">cached</span>
      <button onclick="refreshAiPanel('<%= panelId %>')" class="text-xs" style="color:#64748b;background:none;border:none;cursor:pointer;" title="Refresh">↻ refresh</button>
    </div>
  </div>
  <div class="ai-loading hidden" style="display:flex;align-items:center;gap:0.5rem;font-size:0.75rem;color:#64748b;padding:0.25rem 0;">
    <svg class="animate-spin" style="width:12px;height:12px;color:#0ea5e9;" fill="none" viewBox="0 0 24 24">
      <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
      <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/>
    </svg>
    Analyzing...
  </div>
  <div class="ai-body hidden text-xs leading-relaxed" style="white-space:pre-wrap;overflow-y:auto;max-height:220px;color:#94a3b8;"></div>
  <div class="ai-empty text-xs" style="color:#475569;">AI analysis will appear here.</div>
</div>

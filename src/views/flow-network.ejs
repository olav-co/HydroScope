<%- include('partials/head', { title: 'Flow Network' }) %>
<%- include('partials/nav') %>

<script src="https://cdn.jsdelivr.net/npm/d3@7/dist/d3.min.js"></script>
<link rel="stylesheet" href="https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.css"/>
<script src="https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.js"></script>

<style>
/* ── chips ───────────────────────────────────────────────────────────────────*/
.fn-chip {
  display:inline-flex; align-items:center; gap:6px;
  padding:5px 11px; border-radius:20px; border:1px solid #334155;
  background:transparent; color:#64748b; font-size:12px; cursor:pointer;
  user-select:none; transition:all 0.15s;
}
.fn-chip:hover { border-color:#475569; color:#94a3b8; }
.fn-chip.active { background:#0ea5e9; border-color:#0ea5e9; color:#fff; }
.fn-chip .cdot { width:7px; height:7px; border-radius:50%; background:#334155; transition:background 0.15s; }
.fn-chip.active .cdot { background:rgba(255,255,255,0.5); }
.param-chip {
  padding:4px 11px; border-radius:20px; border:1px solid #334155;
  background:transparent; color:#64748b; font-size:11px; cursor:pointer;
  transition:all 0.15s; user-select:none;
}
.param-chip:hover { border-color:#475569; color:#94a3b8; }
.param-chip.active { background:#334155; border-color:#475569; color:#e2e8f0; }

/* ── canvas card ─────────────────────────────────────────────────────────────*/
#canvas-card {
  position: relative;
  transition: border-radius 0.15s, box-shadow 0.15s;
}
#canvas-card.fn-fullscreen {
  position: fixed;
  inset: 0;
  z-index: 999;
  border-radius: 0 !important;
  background: #0a1628;
  display: flex;
  flex-direction: column;
}
#canvas-card.fn-fullscreen {
  height: 100vh !important;
}

/* ── svg canvas ──────────────────────────────────────────────────────────────*/
#network-svg { width:100%; display:block; background:#0a1628; }
.node-name  { font-family:'Inter',sans-serif; font-weight:600; font-size:11.5px; }
.node-param { font-family:'JetBrains Mono','Courier New',monospace; font-size:10px; }
.link-path  { fill:none; }
.link-halo  { fill:none; pointer-events:none; }
.link-label {
  font-family:'Inter',sans-serif; pointer-events:none; user-select:none;
  paint-order: stroke fill;
  stroke: rgba(10,22,40,0.88);
  stroke-width: 5px;
  stroke-linejoin: round;
}

/* ── countdown bar ───────────────────────────────────────────────────────────*/
.analysis-bar-track {
  position:absolute; bottom:0; left:0; right:0; height:2px;
  overflow:hidden; border-radius:0 0 8px 8px; pointer-events:none;
}
#analysis-progress-bar {
  height:100%; width:0%; background:linear-gradient(90deg,#0ea5e9,#38bdf8);
  transition:none;
}

/* ── node (StreamSets-style compact) ────────────────────────────────────────*/
.node-group { cursor:pointer; }
.node-group:active { cursor:grabbing; }
.node-group rect.node-body { transition:filter 0.15s; }
.node-group:hover rect.node-body { filter:brightness(1.18); }

/* ── slideover ───────────────────────────────────────────────────────────────*/
#fn-slideover {
  position:fixed; top:0; right:0; height:100vh; width:520px;
  background:#0a1628; border-left:2px solid #1e293b;
  z-index:1001; transform:translateX(100%);
  transition:transform 0.25s cubic-bezier(0.4,0,0.2,1);
  display:flex; flex-direction:column; overflow:hidden;
}
@media(max-width:560px){ #fn-slideover{ width:100vw; } }
#fn-slideover-backdrop {
  position:fixed; inset:0; z-index:1000;
  background:rgba(0,0,0,0.35); display:none;
  backdrop-filter:blur(1px);
}
/* collapsible sections */
.so-sect { border-bottom:1px solid #0f1f35; }
.so-sect:last-child { border-bottom:none; }
.so-sect-hdr {
  display:flex; align-items:center; justify-content:space-between;
  padding:10px 18px 9px; cursor:pointer; user-select:none;
  transition:background 0.12s;
}
.so-sect-hdr:hover { background:rgba(255,255,255,0.025); }
.so-sect-body { padding:0 18px 14px; }
.so-section-label {
  font-size:9px; font-weight:700; letter-spacing:.1em; text-transform:uppercase;
  color:#475569;
}
.so-async-ph {
  font-size:11px; color:#334155; display:flex; align-items:center; gap:6px;
  padding:6px 0;
}
.so-reading-row {
  display:flex; align-items:center; justify-content:space-between;
  padding:8px 12px; border-radius:7px; margin-bottom:5px;
  border:1px solid rgba(255,255,255,0.04);
}
.so-conn-row {
  display:flex; align-items:center; gap:9px; padding:8px 11px;
  border-radius:7px; margin-bottom:5px; border:1px solid transparent;
}
.so-sparkline-row {
  display:flex; align-items:center; gap:10px;
  padding:6px 0; border-bottom:1px solid #0f1f35;
}
.so-sparkline-row:last-child { border-bottom:none; }
.so-flood-bar {
  position:relative; height:10px; border-radius:5px;
  background:#0f1f35; overflow:visible; margin:8px 0 4px;
}
.so-flood-marker {
  position:absolute; top:-3px; width:3px; height:16px;
  border-radius:2px; transform:translateX(-50%);
}
.so-stage-pip {
  position:absolute; top:0; left:0; height:100%;
  border-radius:5px; transition:width 0.4s;
}
.so-badge {
  display:inline-flex; align-items:center; gap:4px;
  font-size:9px; font-weight:700; padding:2px 7px;
  border-radius:4px; letter-spacing:.06em; text-transform:uppercase;
}
.so-sitrep-btn {
  width:100%; padding:8px 0; border-radius:7px; border:1px solid #334155;
  background:transparent; color:#94a3b8; font-size:11px; font-weight:600;
  cursor:pointer; transition:all 0.15s; letter-spacing:.04em;
}
.so-sitrep-btn:hover { border-color:#0ea5e9; color:#e2e8f0; background:rgba(14,165,233,0.06); }
.so-sitrep-btn:disabled { opacity:0.5; cursor:default; }
@keyframes spin { to { transform: rotate(360deg); } }

/* ── map view ────────────────────────────────────────────────────────────────*/
#map-view { display:none; width:100%; min-height:458px; }
#canvas-card.fn-fullscreen #map-view { flex:1; min-height:unset !important; height:0 !important; }

/* Animated flow lines — dashes march downstream */
@keyframes flow-march { to { stroke-dashoffset: -40; } }
.flow-line-anim { animation: flow-march 1.4s linear infinite; }
.flow-line-anim-fast { animation: flow-march 0.7s linear infinite; }
.flow-line-anim-slow { animation: flow-march 2.4s linear infinite; }
/* MapLibre GL overrides */
.fn-map-site-label {
  background:rgba(8,18,32,0.92); border:1px solid rgba(255,255,255,0.18); border-radius:4px;
  color:#f1f5f9; font-size:10px; font-weight:600; padding:2px 7px;
  white-space:nowrap; box-shadow:0 1px 4px rgba(0,0,0,0.4); pointer-events:none;
  position:absolute; bottom:calc(100% + 4px); left:50%; transform:translateX(-50%);
}
.maplibregl-popup-content {
  background:#0f172a !important; border:1px solid #334155 !important; border-radius:8px !important;
  box-shadow:0 4px 20px rgba(0,0,0,0.5) !important; color:#e2e8f0 !important;
  padding:10px 14px !important; font-family:Inter,sans-serif;
}
.maplibregl-popup-tip { border-top-color:#0f172a !important; border-bottom-color:#0f172a !important; }
.maplibregl-popup-close-button { color:#64748b !important; font-size:16px !important; }
.maplibregl-ctrl-group { background:#0f172a !important; border-color:#334155 !important; }
.maplibregl-ctrl-group button { background:#0f172a !important; color:#94a3b8 !important; }
.maplibregl-ctrl-group button:hover { background:#1e293b !important; color:#e2e8f0 !important; }
.maplibregl-ctrl-attrib { background:rgba(15,23,42,0.8) !important; color:#475569 !important; font-size:9px; }
.maplibregl-ctrl-attrib a { color:#64748b !important; }

/* ── nldi badge ──────────────────────────────────────────────────────────────*/
.nldi-badge {
  font-size:9px; font-weight:700; padding:1px 5px; border-radius:3px;
  background:rgba(99,102,241,0.2); color:#a5b4fc; letter-spacing:.05em; text-transform:uppercase;
}

/* ── AI panel ────────────────────────────────────────────────────────────────*/
.impl-card { border-radius:8px; padding:10px 14px; margin-bottom:8px; background:rgba(30,41,59,0.7); border:1px solid #1e293b; }
.impl-card.warning  { border-color:rgba(251,146,60,0.3); background:rgba(251,146,60,0.06); }
.impl-card.critical { border-color:rgba(239,68,68,0.4);  background:rgba(239,68,68,0.07); }
.impl-card.watch    { border-color:rgba(250,204,21,0.3);  background:rgba(250,204,21,0.05); }
.sev-badge { font-size:9px; font-weight:700; padding:1px 6px; border-radius:3px; text-transform:uppercase; letter-spacing:.07em; }
.sev-info     { background:rgba(14,165,233,0.2);  color:#38bdf8; }
.sev-watch    { background:rgba(250,204,21,0.2);  color:#fde047; }
.sev-warning  { background:rgba(251,146,60,0.2);  color:#fdba74; }
.sev-critical { background:rgba(239,68,68,0.25);  color:#fca5a5; }

/* ── connection sidebar ──────────────────────────────────────────────────────*/
.conn-row { display:flex; align-items:center; gap:6px; padding:5px 8px; background:#0f172a; border:1px solid #1e293b; border-radius:6px; font-size:11px; }
.conn-from { color:#38bdf8; font-weight:500; max-width:70px; overflow:hidden; white-space:nowrap; text-overflow:ellipsis; }
.conn-arrow { color:#475569; font-size:11px; flex-shrink:0; }
.conn-to   { color:#34d399; font-weight:500; flex:1; overflow:hidden; white-space:nowrap; text-overflow:ellipsis; }
</style>

<main class="flex-1 flex flex-col overflow-hidden">
  <header class="flex items-center justify-between px-6 py-4 border-b border-slate-800" style="background:rgba(15,23,42,0.6);">
    <div>
      <h1 class="text-lg font-semibold text-white">Flow Network</h1>
      <p class="text-xs text-slate-400 mt-0.5">Sites positioned by geographic coordinates · topology from USGS NLDI · AI analysis auto-updates on selection change</p>
    </div>
    <div class="flex items-center gap-3">
      <span id="sync-status" class="text-xs text-slate-600"></span>
      <button id="syncBtn" onclick="syncTopology()" class="fn-chip" style="border-radius:6px;font-size:11px;">
        <svg style="width:11px;height:11px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
        Discover Topology
      </button>
      <select id="fnHours" class="input" style="font-size:12px;padding:5px 10px;">
        <option value="24">24 Hours</option>
        <option value="72" selected>3 Days</option>
        <option value="168">7 Days</option>
      </select>
    </div>
  </header>

  <div class="flex-1 overflow-y-auto p-5 flex flex-col gap-5">

    <!-- Controls -->
    <div class="card">
      <div class="flex flex-col gap-4">

        <!-- Group + Basin row -->
        <div class="flex gap-4 items-start">

          <!-- Group quick-load -->
          <div style="flex:0 0 220px;">
            <label class="label mb-1.5">Group</label>
            <select id="fn-group-select" onchange="fnLoadGroup(this.value)"
              style="width:100%;padding:5px 10px;background:#0f172a;border:1px solid #334155;
                     border-radius:6px;color:#e2e8f0;font-size:12px;outline:none;cursor:pointer;">
              <option value="">All sites</option>
            </select>
          </div>

          <!-- AND / OR toggle — only meaningful when both are active -->
          <div style="flex:0 0 auto;padding-top:22px;">
            <div id="fn-mode-toggle" style="display:flex;border:1px solid #334155;border-radius:6px;overflow:hidden;">
              <button id="fn-mode-or"  onclick="fnSetFilterMode('or')"
                style="padding:4px 10px;font-size:11px;font-weight:600;border:none;cursor:pointer;
                       background:#0ea5e9;color:#fff;transition:all 0.15s;">OR</button>
              <button id="fn-mode-and" onclick="fnSetFilterMode('and')"
                style="padding:4px 10px;font-size:11px;font-weight:600;border:none;cursor:pointer;
                       background:#0f172a;color:#475569;transition:all 0.15s;">AND</button>
            </div>
          </div>

          <!-- Basin multi-selector -->
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 mb-1.5 flex-wrap">
              <label class="label mb-0" style="flex-shrink:0;">Basins</label>
              <div id="fn-basin-tags" class="flex flex-wrap gap-1.5"></div>
            </div>
            <div style="position:relative;">
              <input id="fnBasinInput" type="text" autocomplete="off"
                placeholder="Add a watershed…"
                oninput="_fnBasinInput(this.value)"
                onfocus="_fnOpenBasin()"
                onkeydown="_fnBasinKeydown(event)"
                style="width:100%;padding:5px 28px 5px 10px;background:#0f172a;border:1px solid #334155;
                       border-radius:6px;color:#e2e8f0;font-size:12px;box-sizing:border-box;outline:none;"/>
              <span style="position:absolute;right:9px;top:50%;transform:translateY(-50%);color:#475569;font-size:11px;pointer-events:none;">▾</span>
              <div id="fnBasinDropdown"
                style="display:none;position:absolute;top:calc(100% + 3px);left:0;right:0;z-index:200;
                       background:#0f172a;border:1px solid #334155;border-radius:7px;
                       max-height:220px;overflow-y:auto;box-shadow:0 6px 20px rgba(0,0,0,0.5);">
              </div>
            </div>
          </div>

        </div>

        <div>
          <div class="flex items-center gap-3 mb-2 flex-wrap">
            <label class="label mb-0" style="flex-shrink:0;">Sites <span class="text-slate-600 font-normal">(select any · cross-selectable)</span></label>
            <div class="flex items-center gap-2 ml-auto">
              <button onclick="fnSelectAllSites()" class="text-xs" style="background:none;border:none;cursor:pointer;color:#38bdf8;padding:0;" onmouseover="this.style.color='#7dd3fc'" onmouseout="this.style.color='#38bdf8'">Select all</button>
              <span style="color:#334155;font-size:10px;">|</span>
              <button onclick="fnDeselectAllSites()" class="text-xs" style="background:none;border:none;cursor:pointer;color:#64748b;padding:0;" onmouseover="this.style.color='#94a3b8'" onmouseout="this.style.color='#64748b'">Deselect all</button>
              <span style="color:#334155;font-size:10px;">|</span>
              <span id="site-count" class="text-xs text-slate-600">0 selected</span>
            </div>
          </div>
          <%
            var usgsSitesFN = sites.filter(function(s){ return s.source !== 'cwms'; });
            var cwmsSitesFN = sites.filter(function(s){ return s.source === 'cwms'; });
            var colors = ['#0ea5e9','#a78bfa','#34d399','#fb923c','#f472b6','#facc15','#e879f9','#22d3ee','#4ade80','#f97316','#818cf8','#fbbf24'];
          %>

          <!-- placeholder shown until a basin is selected -->
          <div id="fn-basin-hint" style="padding:10px 0;font-size:12px;color:#475569;">
            Select a basin above to see available sites.
          </div>

          <div id="site-chips" class="flex flex-col gap-3" style="display:none;">
            <% if (usgsSitesFN.length) { %>
            <div id="fn-usgs-group">
              <div class="text-xs font-semibold mb-1.5" style="color:#38bdf8;letter-spacing:.06em;text-transform:uppercase;">
                <span style="font-size:9px;padding:1px 5px;border-radius:3px;background:rgba(14,165,233,0.12);border:1px solid rgba(14,165,233,0.25);margin-right:5px;">USGS</span>Stream Gauges
              </div>
              <div class="flex flex-wrap gap-2" id="fn-usgs-chips">
                <% usgsSitesFN.forEach(function(s, i) { var c = colors[i % colors.length]; %>
                <button class="fn-chip" data-id="<%= s.site_id %>" data-name="<%= s.name %>" data-color="<%= c %>" data-source="usgs" data-huc8="<%= s.huc8_code || '' %>" onclick="toggleSite(this)">
                  <span class="cdot"></span>
                  <%= s.name %>
                </button>
                <% }); %>
              </div>
            </div>
            <% } %>
            <% if (cwmsSitesFN.length) { %>
            <div id="fn-cwms-group">
              <div class="text-xs font-semibold mb-1.5" style="color:#f59e0b;letter-spacing:.06em;text-transform:uppercase;">
                <span style="font-size:9px;padding:1px 5px;border-radius:3px;background:rgba(245,158,11,0.12);border:1px solid rgba(245,158,11,0.3);margin-right:5px;">CWMS</span>Dam Operations
              </div>
              <div class="flex flex-wrap gap-2" id="fn-cwms-chips">
                <% cwmsSitesFN.forEach(function(s, i) { var c = ['#f59e0b','#fb923c','#fbbf24','#e879f9'][i % 4]; %>
                <button class="fn-chip" data-id="<%= s.site_id %>" data-name="<%= s.name %>" data-color="<%= c %>" data-source="cwms" data-huc8="<%= s.huc8_code || '' %>" onclick="toggleSite(this)">
                  <span class="cdot"></span>
                  ⬡ <%= s.name %>
                </button>
                <% }); %>
              </div>
            </div>
            <% } %>
          </div>
        </div>
        <div>
          <label class="label mb-2">Parameters <span class="text-slate-600 font-normal">(select any · shown on nodes)</span></label>
          <div class="flex flex-wrap gap-2" id="param-chips">
            <div class="w-full text-xs font-medium mb-1" style="color:#38bdf8;opacity:0.7;">USGS</div>
            <button class="param-chip active" data-code="00060" data-name="Discharge"    data-unit="ft³/s" onclick="toggleParam(this)">Discharge (ft³/s)</button>
            <button class="param-chip active" data-code="00065" data-name="Gage Height"  data-unit="ft"    onclick="toggleParam(this)">Gage Height (ft)</button>
            <button class="param-chip"        data-code="00010" data-name="Water Temp"   data-unit="°C"    onclick="toggleParam(this)">Temperature (°C)</button>
            <button class="param-chip"        data-code="00300" data-name="DO"           data-unit="mg/L"  onclick="toggleParam(this)">Dissolved O₂ (mg/L)</button>
            <button class="param-chip"        data-code="00400" data-name="pH"           data-unit=""      onclick="toggleParam(this)">pH</button>
            <div class="w-full text-xs font-medium mt-2 mb-1" style="color:#f59e0b;opacity:0.7;">CWMS</div>
            <button class="param-chip active" data-code="Elev-Pool"  data-name="Pool Elevation" data-unit="ft"    onclick="toggleParam(this)">Pool Elev (ft)</button>
            <button class="param-chip active" data-code="Flow"       data-name="Outflow"         data-unit="cfs"   onclick="toggleParam(this)">Outflow (cfs)</button>
            <button class="param-chip"        data-code="Flow-In"    data-name="Inflow"           data-unit="cfs"   onclick="toggleParam(this)">Inflow (cfs)</button>
            <button class="param-chip"        data-code="Elev-Tail"  data-name="Tailwater Elev"  data-unit="ft"    onclick="toggleParam(this)">Tailwater (ft)</button>
            <button class="param-chip"        data-code="Stor"       data-name="Storage"          data-unit="ac-ft" onclick="toggleParam(this)">Storage (ac-ft)</button>
            <button class="param-chip"        data-code="Conc-Do-Tail" data-name="DO Tailwater"   data-unit="mg/L"  onclick="toggleParam(this)">DO Tail (mg/L)</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Network + right panel -->
    <div class="flex gap-4" style="align-items:stretch;">

      <div id="canvas-card" class="card flex-1" style="padding:0;overflow:hidden;min-height:500px;height:calc(100vh - 290px);display:flex;flex-direction:column;">
        <!-- toolbar -->
        <div class="flex items-center gap-2 px-4 py-2" style="border-bottom:1px solid #1e293b;flex-shrink:0;">
          <span class="nldi-badge">USGS NLDI</span>
          <span id="view-hint" class="text-xs text-slate-600">Geographic lat/lon layout · drag nodes to adjust · topology from NLDI</span>
          <button onclick="resetLayout()" id="resetBtn" class="text-xs text-slate-600 hover:text-slate-300 ml-auto" style="background:none;border:none;cursor:pointer;" title="Reset positions">↺ Reset</button>
          <button onclick="toggleMapMode()" id="mapToggleBtn" class="text-xs text-slate-500 hover:text-slate-300" style="background:none;border:none;cursor:pointer;padding:2px 8px;border:1px solid #334155;border-radius:4px;" title="Switch to real map view">
            ⊕ Map
          </button>
          <button onclick="toggleRadarLayer()" id="radarToggleBtn" class="text-xs text-slate-500 hover:text-slate-300" style="background:none;border:none;cursor:pointer;padding:2px 8px;border:1px solid #334155;border-radius:4px;display:none;" title="Toggle precipitation radar overlay">
            🌧 Radar
          </button>
          <button onclick="toggleFullscreen()" id="expandBtn" class="text-xs text-slate-500 hover:text-slate-300" style="background:none;border:none;cursor:pointer;padding:2px 6px;border:1px solid #334155;border-radius:4px;" title="Expand / collapse">
            <span id="expand-label">⛶</span>
          </button>
        </div>

        <div id="canvas-empty" class="absolute inset-0 flex items-center justify-center pointer-events-none" style="top:42px;">
          <p class="text-sm text-slate-600">Select 2 or more sites above to draw the network</p>
        </div>

        <svg id="network-svg" style="flex:1;min-height:0;width:100%;display:block;"></svg>
        <div id="map-view" style="flex:1;min-height:0;position:relative;">
          <div id="flowline-status" style="display:none;position:absolute;bottom:10px;left:50%;transform:translateX(-50%);z-index:1000;align-items:center;gap:6px;background:rgba(10,22,40,0.88);border:1px solid #1e293b;border-radius:20px;padding:5px 14px;font-size:11px;font-weight:600;color:#94a3b8;pointer-events:none;white-space:nowrap;">
            <svg class="animate-spin" width="12" height="12" viewBox="0 0 24 24" style="flex-shrink:0;color:#38bdf8;" fill="none"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/></svg>
            <span id="flowline-status-text"></span>
          </div>
        </div>
      </div>

      <!-- Right column: AI analysis -->
      <div style="width:300px;flex-shrink:0;display:flex;flex-direction:column;height:calc(100vh - 290px);min-height:500px;">

        <!-- AI Analysis (auto, no button) -->
        <div id="ai-panel" class="card" style="display:none;position:relative;overflow:hidden;flex:1;overflow-y:auto;">
          <!-- countdown progress bar -->
          <div class="analysis-bar-track"><div id="analysis-progress-bar"></div></div>

          <div class="flex items-center gap-2 mb-4">
            <span class="ai-badge">AI</span>

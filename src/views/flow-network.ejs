      </div><!-- /right column -->

    </div>

    <!-- Flow Connections (bottom) -->
    <div id="conn-panel" class="card" style="padding:14px 18px;">
      <div class="flex items-center gap-2 mb-3">
        <div class="text-xs font-medium text-slate-500 uppercase tracking-wider">Flow Connections</div>
        <span class="nldi-badge">NLDI</span>
      </div>
      <div id="conn-list" class="flex flex-wrap gap-2 text-xs text-slate-600">Discovering…</div>
    </div>

  </div>
</main>

<!-- ── Slideover ───────────────────────────────────────────────────────────── -->
<div id="fn-slideover-backdrop" onclick="closeSlideover()"></div>
<div id="fn-slideover">
  <div id="so-header" style="padding:16px 18px;border-bottom:1px solid #1e293b;flex-shrink:0;display:flex;align-items:center;gap:10px;">
    <div id="so-icon" style="width:36px;height:36px;border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
      <svg width="18" height="18" viewBox="0 0 18 18" id="so-icon-svg" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></svg>
    </div>
    <div style="flex:1;min-width:0;">
      <div id="so-site-name" style="font-weight:700;font-size:14px;color:#e2e8f0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"></div>
      <div id="so-site-meta" style="font-size:10px;color:#475569;margin-top:1px;"></div>
    </div>
    <button onclick="closeSlideover()" style="background:none;border:none;cursor:pointer;color:#475569;font-size:20px;line-height:1;padding:4px;flex-shrink:0;" title="Close">&times;</button>
  </div>
  <div id="so-body" style="flex:1;overflow-y:auto;padding:18px;display:flex;flex-direction:column;gap:20px;"></div>
</div>

<script>
// ── State ─────────────────────────────────────────────────────────────────────
var SITES       = <%- JSON.stringify(sites) %>;
var INIT_CONNS  = <%- JSON.stringify(connections) %>;

// ── Group + Basin unified filter ──────────────────────────────────────────────
var _fnGroupSiteIds = new Set();
var _fnFilterMode   = 'or'; // 'or' | 'and'

(function _loadFnGroups() {
  fetch('/api/groups')
    .then(function(r) { return r.json(); })
    .then(function(groups) {
      var sel = document.getElementById('fn-group-select');
      if (!sel) return;
      groups.forEach(function(g) {
        var opt = document.createElement('option');
        opt.value = g.id;
        opt.textContent = g.name + ' (' + g.member_count + ' sites)';
        sel.appendChild(opt);
      });
    })
    .catch(function() {});
}());

function fnLoadGroup(groupId) {
  if (!groupId) {
    _fnGroupSiteIds = new Set();
    _fnApplyVisibilityFilter();
    return;
  }
  fetch('/api/groups/' + groupId + '/members')
    .then(function(r) { return r.json(); })
    .then(function(siteIds) {
      _fnGroupSiteIds = new Set(siteIds);
      _fnApplyVisibilityFilter();
    })
    .catch(function(e) { console.error('fnLoadGroup', e); });
}

function fnSetFilterMode(mode) {
  _fnFilterMode = mode;
  document.getElementById('fn-mode-or').style.background  = mode === 'or'  ? '#0ea5e9' : '#0f172a';
  document.getElementById('fn-mode-or').style.color        = mode === 'or'  ? '#fff'    : '#475569';
  document.getElementById('fn-mode-and').style.background = mode === 'and' ? '#0ea5e9' : '#0f172a';
  document.getElementById('fn-mode-and').style.color       = mode === 'and' ? '#fff'    : '#475569';
  _fnApplyVisibilityFilter();
}

function _fnApplyVisibilityFilter() {
  var hint      = document.getElementById('fn-basin-hint');
  var chipsWrap = document.getElementById('site-chips');
  var basins    = _fnActiveBasins.map(function(b) { return b.code; });
  var hasBasin  = basins.length > 0;
  var hasGroup  = _fnGroupSiteIds.size > 0;

  // Nothing selected → show prompt, hide chips
  if (!hasBasin && !hasGroup) {
    if (hint)      hint.style.display = '';
    if (chipsWrap) chipsWrap.style.display = 'none';
    _selectedSites = [];
    document.querySelectorAll('#site-chips .fn-chip.active').forEach(function(btn) {
      btn.classList.remove('active');
      btn.querySelector('.cdot').style.background = '#334155';
    });
    document.getElementById('site-count').textContent = '0 selected';
    if (_mapMode) renderMaplibreMap(); else redrawNetwork();
    return;
  }

  if (hint)      hint.style.display = 'none';
  if (chipsWrap) chipsWrap.style.display = 'flex';

  document.querySelectorAll('#site-chips .fn-chip').forEach(function(btn) {
    var huc    = btn.getAttribute('data-huc8') || '';
    var sid    = btn.getAttribute('data-id')   || '';
    var inBas  = hasBasin && basins.indexOf(huc) !== -1;
    var inGrp  = hasGroup && _fnGroupSiteIds.has(sid);

    var visible;
    if (hasBasin && hasGroup) {
      visible = _fnFilterMode === 'and' ? (inBas && inGrp) : (inBas || inGrp);
    } else if (hasBasin) {
      visible = inBas;
    } else {
      visible = inGrp;
    }

    btn.style.display = visible ? '' : 'none';
    if (!visible && btn.classList.contains('active')) {
      btn.classList.remove('active');
      btn.querySelector('.cdot').style.background = '#334155';
      _selectedSites = _selectedSites.filter(function(s) { return s.site_id !== sid; });
    }
  });

  // Hide group headers if all their chips are hidden
  ['fn-usgs-group','fn-cwms-group'].forEach(function(id) {
    var grp = document.getElementById(id);
    if (!grp) return;
    var anyVis = Array.from(grp.querySelectorAll('.fn-chip')).some(function(b) { return b.style.display !== 'none'; });
    grp.style.display = anyVis ? '' : 'none';
  });

  document.getElementById('site-count').textContent = _selectedSites.length + ' selected';
  if (_mapMode) renderMaplibreMap(); else redrawNetwork();
}

// ── Basin multi-selector ──────────────────────────────────────────────────────
var _fnBasinOpts    = [];
var _fnBasinHiIdx   = -1;
var _fnActiveBasins = [];  // [{code, display, color}, ...]
var _FN_BASIN_COLORS = ['#38bdf8','#a78bfa','#34d399','#fb923c','#f472b6','#facc15','#22d3ee','#4ade80'];

(async function _loadFnBasins() {
  try {
    var r = await fetch('/api/basins');
    var basins = await r.json();
    if (!Array.isArray(basins)) return;
    _fnBasinOpts = basins.map(function(b) {
      return { code: b.huc8_code,
               display: b.huc8_name ? b.huc8_name + ' (' + b.huc8_code + ')' : b.huc8_code,
               name: b.huc8_name || b.huc8_code,
               is_favorite: !!b.is_favorite };
    });
  } catch (_) {}
})();

async function _fnToggleFavorite(code, name, ev) {
  if (ev) ev.stopPropagation();
  var opt = _fnBasinOpts.find(function(b) { return b.code === code; });
  if (!opt) return;
  var wasFav = opt.is_favorite;
  opt.is_favorite = !wasFav;
  try {
    if (wasFav) {
      await fetch('/api/users/favorites/' + code, { method: 'DELETE' });
    } else {
      await fetch('/api/users/favorites/' + code, { method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ huc8_name: name }) });
    }
  } catch (_) { opt.is_favorite = wasFav; }
  // Refresh the tag for the active basin if it's selected
  _fnRenderBasinTags();
  _fnRenderBasinDropdown(document.getElementById('fnBasinInput') ? document.getElementById('fnBasinInput').value : '');
}

// Return degree-distance between two basin centroids (uses SITES lat/lon).
function _fnBasinCentroid(code) {
  var pts = SITES.filter(function(s) { return s.huc8_code === code && s.latitude && s.longitude; });
  if (!pts.length) return null;
  return {
    lat: pts.reduce(function(a, s) { return a + s.latitude;  }, 0) / pts.length,
    lon: pts.reduce(function(a, s) { return a + s.longitude; }, 0) / pts.length
  };
}

function _fnBasinDist(codeA, codeB) {
  var a = _fnBasinCentroid(codeA), b = _fnBasinCentroid(codeB);
  if (!a || !b) return Infinity;
  var dlat = a.lat - b.lat, dlon = a.lon - b.lon;
  return Math.sqrt(dlat * dlat + dlon * dlon);
}

// Top-N unused basins sorted by min-distance to any active basin.
function _fnGetRecommended(limit) {
  if (!_fnActiveBasins.length) return [];
  var activeCodes = _fnActiveBasins.map(function(b) { return b.code; });
  return _fnBasinOpts
    .filter(function(b) { return activeCodes.indexOf(b.code) === -1; })
    .map(function(b) {
      var d = Math.min.apply(null, _fnActiveBasins.map(function(ab) { return _fnBasinDist(ab.code, b.code); }));
      return { code: b.code, display: b.display, name: b.name, is_favorite: b.is_favorite, dist: d };
    })
    .filter(function(b) { return isFinite(b.dist); })
    .sort(function(a, b) { return a.dist - b.dist; })
    .slice(0, limit || 5);
}

function _fnBasinFiltered(q) {
  var activeCodes = _fnActiveBasins.map(function(b) { return b.code; });
  var opts = _fnBasinOpts.filter(function(b) { return activeCodes.indexOf(b.code) === -1; });
  if (!q) return opts;
  var lq = q.toLowerCase();
  return opts.filter(function(b) { return b.display.toLowerCase().indexOf(lq) !== -1; });
}

function _fnMakeOpt(b, idx) {
  var star = b.is_favorite
    ? '<span style="color:#facc15;font-size:13px;margin-right:5px;flex-shrink:0;" title="Remove from favorites" onclick="_fnToggleFavorite(\''+b.code+'\',\''+b.name.replace(/'/g,'&#39;')+'\',event)">★</span>'
    : '<span style="color:#334155;font-size:13px;margin-right:5px;flex-shrink:0;" title="Add to favorites" onclick="_fnToggleFavorite(\''+b.code+'\',\''+b.name.replace(/'/g,'&#39;')+'\',event)">☆</span>';
  return '<div class="_fn-bopt" data-code="' + b.code + '"'
    + ' onclick="_fnPickBasin(\'' + b.code + '\',\'' + b.display.replace(/'/g, '&#39;') + '\')"'
    + ' onmouseenter="_fnBasinHover(' + idx + ')"'
    + ' style="display:flex;align-items:center;padding:7px 12px;font-size:12px;color:#94a3b8;cursor:pointer;">'
    + star + '<span>' + b.display + '</span></div>';
}

function _fnSectionLabel(text) {
  return '<div style="padding:4px 12px 2px;font-size:9px;font-weight:700;letter-spacing:.08em;'
    + 'text-transform:uppercase;color:#334155;">' + text + '</div>';
}

function _fnRenderBasinDropdown(q) {
  var dd = document.getElementById('fnBasinDropdown');
  if (!dd) return;
  _fnBasinHiIdx = -1;

  if (q) {
    var hits = _fnBasinFiltered(q);
    if (!hits.length) {
      dd.innerHTML = '<div style="padding:8px 12px;font-size:12px;color:#475569;">No matching basins</div>';
      return;
    }
    dd.innerHTML = hits.slice(0, 60).map(_fnMakeOpt).join('');
    return;
  }

  // Empty query — favorites first, then recommended nearby, then all
  var activeCodes = _fnActiveBasins.map(function(b) { return b.code; });
  var available   = _fnBasinOpts.filter(function(b) { return activeCodes.indexOf(b.code) === -1; });
  var favs        = available.filter(function(b) { return b.is_favorite; });
  var nonFavs     = available.filter(function(b) { return !b.is_favorite; });

  var recommended = _fnGetRecommended(5).filter(function(b) { return !b.is_favorite; });
  var recCodes    = recommended.map(function(b) { return b.code; });
  var rest        = nonFavs.filter(function(b) { return recCodes.indexOf(b.code) === -1; });

  if (!available.length) {
    dd.innerHTML = '<div style="padding:8px 12px;font-size:12px;color:#475569;">'
      + (_fnBasinOpts.length ? 'All basins already added' : 'No basins — run Basin Geometry sync')
      + '</div>';
    return;
  }

  var html = '';
  var idx  = 0;
  if (favs.length) {
    html += _fnSectionLabel('★ Favorites');
    html += favs.map(function(b) { return _fnMakeOpt(b, idx++); }).join('');
    html += '<div style="height:1px;background:#1e293b;margin:3px 0;"></div>';
  }
  if (recommended.length) {
    html += _fnSectionLabel('Suggested nearby');
    html += recommended.map(function(b) { return _fnMakeOpt(b, idx++); }).join('');
    if (rest.length) {
      html += '<div style="height:1px;background:#1e293b;margin:3px 0;"></div>';
      html += _fnSectionLabel('All basins');
    }
  } else if (rest.length) {
    html += _fnSectionLabel('All basins');
  }
  html += rest.slice(0, 60).map(function(b) { return _fnMakeOpt(b, idx++); }).join('');
  dd.innerHTML = html;
}

function _fnBasinHover(i) {
  _fnBasinHiIdx = i;
  document.querySelectorAll('._fn-bopt').forEach(function(el, j) {
    el.style.background = j === i ? '#1e293b' : '';
    el.style.color      = j === i ? '#e2e8f0' : '#94a3b8';
  });
}

function _fnOpenBasin() {
  var inp = document.getElementById('fnBasinInput');
  _fnRenderBasinDropdown(inp ? inp.value : '');
  var dd = document.getElementById('fnBasinDropdown');
  if (dd) dd.style.display = 'block';
}

function _fnBasinInput(val) {
  _fnRenderBasinDropdown(val);
  var dd = document.getElementById('fnBasinDropdown');
  if (dd) dd.style.display = 'block';
}

function _fnBasinKeydown(e) {
  var dd = document.getElementById('fnBasinDropdown');
  if (!dd || dd.style.display === 'none') return;
  var opts = dd.querySelectorAll('._fn-bopt');
  if (!opts.length) return;
  if (e.key === 'ArrowDown') {
    e.preventDefault();
    _fnBasinHover(Math.min(_fnBasinHiIdx + 1, opts.length - 1));
    opts[_fnBasinHiIdx] && opts[_fnBasinHiIdx].scrollIntoView({ block: 'nearest' });
  } else if (e.key === 'ArrowUp') {
    e.preventDefault();
    _fnBasinHover(Math.max(_fnBasinHiIdx - 1, 0));
    opts[_fnBasinHiIdx] && opts[_fnBasinHiIdx].scrollIntoView({ block: 'nearest' });
  } else if (e.key === 'Enter') {
    e.preventDefault();
    var t = _fnBasinHiIdx >= 0 ? opts[_fnBasinHiIdx] : opts[0];
    if (t) _fnPickBasin(t.dataset.code, t.textContent.trim());
  } else if (e.key === 'Escape') {
    if (dd) dd.style.display = 'none';
  }
}

function _fnPickBasin(code, display) {
  var dd = document.getElementById('fnBasinDropdown');
  if (dd) dd.style.display = 'none';
  var inp = document.getElementById('fnBasinInput');
  if (inp) inp.value = '';
  // Skip duplicates
  if (_fnActiveBasins.some(function(b) { return b.code === code; })) return;
  var color = _FN_BASIN_COLORS[_fnActiveBasins.length % _FN_BASIN_COLORS.length];
  _fnActiveBasins.push({ code: code, display: display, color: color });
  _fnRenderBasinTags();
  _fnApplyVisibilityFilter();
}

function _fnRemoveBasin(code) {
  _fnActiveBasins = _fnActiveBasins.filter(function(b) { return b.code !== code; });
  _fnRenderBasinTags();
  _fnApplyVisibilityFilter();
}

function _fnRenderBasinTags() {
  var container = document.getElementById('fn-basin-tags');
  if (!container) return;
  container.innerHTML = _fnActiveBasins.map(function(b) {
    var name = b.display.replace(/ \(\d{8}\)$/, '');
    var opt  = _fnBasinOpts.find(function(o) { return o.code === b.code; });
    var isFav = opt && opt.is_favorite;
    var starBtn = '<button onclick="_fnToggleFavorite(\'' + b.code + '\',\'' + (opt ? opt.name.replace(/'/g,"&#39;") : b.code) + '\',event)" '
      + 'title="' + (isFav ? 'Remove favorite' : 'Add to favorites') + '" '
      + 'style="background:none;border:none;cursor:pointer;padding:0;font-size:12px;line-height:1;'
      + 'color:' + (isFav ? '#facc15' : b.color) + ';opacity:' + (isFav ? '1' : '0.45') + ';">'
      + (isFav ? '★' : '☆') + '</button>';
    return '<span style="display:inline-flex;align-items:center;gap:4px;padding:3px 8px 3px 10px;'
      + 'border-radius:20px;border:1px solid ' + b.color + '44;background:' + b.color + '18;'
      + 'color:' + b.color + ';font-size:11px;font-weight:500;white-space:nowrap;">'
      + name + starBtn
      + '<button onclick="_fnRemoveBasin(\'' + b.code + '\')" '
      + 'style="background:none;border:none;color:' + b.color + ';cursor:pointer;padding:0;'
      + 'font-size:13px;line-height:1;opacity:0.7;" onmouseover="this.style.opacity=\'1\'" onmouseout="this.style.opacity=\'0.7\'">'
      + '×</button></span>';
  }).join('');
}

document.addEventListener('click', function(e) {
  var inp = document.getElementById('fnBasinInput');
  var dd  = document.getElementById('fnBasinDropdown');
  if (inp && dd && !inp.contains(e.target) && !dd.contains(e.target)) dd.style.display = 'none';
});
var SITE_COLORS = ['#0ea5e9','#a78bfa','#34d399','#fb923c','#f472b6','#facc15','#e879f9','#22d3ee','#4ade80','#f97316','#818cf8','#fbbf24'];

var _selectedSites  = [];
var _selectedParams = [];
var _connections    = INIT_CONNS.slice();
var _readings       = {};
var _d3Nodes        = [];   // persisted between renders; each node keeps x,y,targetX,targetY
var _d3Links        = [];
var _simulation     = null;

var ANALYZE_DELAY   = 2500;
var _analyzeTimer   = null;

// Re-run analysis when user updates their profile (role/interests/context change AI framing)
window.addEventListener('hydroProfileUpdated', function() {
  scheduleAnalysis();
});
var _fullscreen     = false;
var _mapMode        = false;
var _radarOn        = false;
var _rvHost         = '';
var _rvLatestPath   = '';
var _mlMap          = null;
var _mlMapReady     = false; // true after 'load' fires and sources/layers are initialized
var _mlMarkers      = [];   // maplibregl.Marker instances (cleared on each render)
var _mlPopups       = [];   // maplibregl.Popup instances
var _mlBasinLayers  = [];   // [{fillId, outlineId}] for cleanup
var _mapRenderToken = 0;    // incremented per render; stale async renders self-abort
var STALE_HOURS     = 6;

// ── Flow-line dash animation (MapLibre equivalent of CSS stroke-dashoffset) ────
// Pre-compute all 22 dasharray phases for a 14-dash / 8-gap pattern (period=22).
// Cycling through them at ~35 ms/step produces the same marching-ants speed as
// the original CSS `flow-march 1.4s` (40 dashoffset units / 1.4 s ≈ 28 u/s;
// 22-unit period / 28 u/s ≈ 0.77 s/cycle ≈ 35 ms/step).
var _DASH_SEQ = (function() {
  var seq = [], D = 14, G = 8, P = D + G;
  for (var k = 0; k < P; k++) {
    if (k === 0)    seq.push([D, G]);
    else if (k < D) seq.push([D-k, G, k]);
    else { var i = k-D; seq.push(i ? [0, G-i, D, i] : [0, G, D]); }
  }
  return seq;
}());
// Three speed tiers matching the original CSS classes:
//   fast   → flow-line-anim-fast  (0.7 s/cycle  → 17 ms/step)
//   normal → flow-line-anim       (1.4 s/cycle  → 35 ms/step)
//   slow   → flow-line-anim-slow  (2.4 s/cycle  → 60 ms/step)
var _DASH_MS    = { slow: 60, normal: 35, fast: 17 };
var _dashSteps  = { slow: 0,  normal: 0,  fast: 0  };
var _dashAccum  = { slow: 0,  normal: 0,  fast: 0  };
var _dashPrev   = 0;
var _dashRaf    = null;

function _startDashAnim() {
  _stopDashAnim();
  _dashPrev = 0;
  function frame(ts) {
    _dashRaf = requestAnimationFrame(frame);
    if (!_mlMap) return;
    var dt = _dashPrev ? Math.min(ts - _dashPrev, 100) : 0;
    _dashPrev = ts;
    ['slow', 'normal', 'fast'].forEach(function(sp) {
      _dashAccum[sp] += dt;
      if (_dashAccum[sp] < _DASH_MS[sp]) return;
      _dashAccum[sp] -= _DASH_MS[sp];
      _dashSteps[sp] = (_dashSteps[sp] + _DASH_SEQ.length - 1) % _DASH_SEQ.length;
      var id = sp === 'normal' ? 'ww-line' : 'ww-line-' + sp;
      try { if (_mlMap.getLayer(id)) _mlMap.setPaintProperty(id, 'line-dasharray', _DASH_SEQ[_dashSteps[sp]]); } catch(_) {}
    });
  }
  _dashRaf = requestAnimationFrame(frame);
}
function _stopDashAnim() {
  if (_dashRaf) { cancelAnimationFrame(_dashRaf); _dashRaf = null; }
  _dashPrev = 0;
  _dashAccum = { slow: 0, normal: 0, fast: 0 };
}

// ── Chip toggles ──────────────────────────────────────────────────────────────
function toggleSite(btn) {
  btn.classList.toggle('active');
  btn.querySelector('.cdot').style.background = btn.classList.contains('active')
    ? btn.dataset.color : '#334155';
  _selectedSites = Array.from(document.querySelectorAll('#site-chips .fn-chip.active')).map(function(b) {
    return { site_id: b.dataset.id, name: b.dataset.name, color: b.dataset.color, source: b.dataset.source };
  });
  document.getElementById('site-count').textContent = _selectedSites.length + ' selected';
  refreshData();
}

function fnSelectAllSites() {
  document.querySelectorAll('#site-chips .fn-chip').forEach(function(btn) {
    if (btn.style.display === 'none') return;
    if (!btn.classList.contains('active')) toggleSite(btn);
  });
}

function fnDeselectAllSites() {
  document.querySelectorAll('#site-chips .fn-chip.active').forEach(function(btn) {
    if (btn.style.display === 'none') return;
    toggleSite(btn);
  });
}

function toggleParam(btn) {
  btn.classList.toggle('active');
  _selectedParams = Array.from(document.querySelectorAll('#param-chips .param-chip.active')).map(function(b) {
    return { code: b.dataset.code, name: b.dataset.name, unit: b.dataset.unit };
  });
  refreshData();
}

// ── Data fetch ────────────────────────────────────────────────────────────────
async function refreshData() {
  var empty = document.getElementById('canvas-empty');
  if (!_selectedSites.length) {
    empty.style.opacity = '1'; empty.style.pointerEvents = 'none';
    redrawNetwork(); renderConnections(); cancelAnalysis();
    return;
  }
  empty.style.opacity = '0';

  var hours = parseInt(document.getElementById('fnHours').value);
  await Promise.all(_selectedSites.map(async function(s) {
    var paramReadings = [];
    for (var p of _selectedParams) {
      try {
        var r = await fetch('/api/data/timeseries?site=' + s.site_id + '&param=' + p.code + '&hours=' + hours);
        var j = await r.json();
        var rows = j.data || [];
        if (!rows.length) continue;
        var first = rows[0].value, last = rows[rows.length-1].value;
        var diff = last - first, pct = Math.abs(diff) / (Math.abs(first) || 1);
        paramReadings.push({
          param_code: p.code, param_name: p.name, unit: p.unit, value: last,
          trend: pct < 0.02 ? 'stable' : diff > 0 ? 'rising' : 'falling',
        });
      } catch(_) {}
    }
    _readings[s.site_id] = paramReadings;
  }));
  if (_mapMode) renderMaplibreMap(); else redrawNetwork();
  renderConnections();
  scheduleAnalysis();
}

// ── Node dimensions (fixed compact size) ─────────────────────────────────────
var NODE_W   = 168;
var NODE_H   = 54;
var ICON_W   = 44;
var _dragMoved = false;
var _dragStartClient = null;
function nodeHeight() { return NODE_H; }
// Collision radius: half-diagonal of the node rectangle + padding
function collisionR() {
  return Math.sqrt((NODE_W/2) * (NODE_W/2) + (NODE_H/2) * (NODE_H/2)) + 10;
}

// ── Geographic targets ────────────────────────────────────────────────────────
// Returns { site_id → {tx, ty} } mapped to canvas (W×H).
// All selected sites are included. Uses ALL selected sites (not just those
// with existing nodes) to build a stable shared coordinate system.
function computeGeoTargets(W, H) {
  var PAD_X = NODE_W / 2 + 28, PAD_Y = 70;

  var withCoords = _selectedSites.map(function(s) {
    var full = SITES.find(function(f){ return f.site_id === s.site_id; }) || {};
    return { id: s.site_id, lat: full.latitude, lon: full.longitude };
  });

  var lats = withCoords.filter(function(w){ return Number.isFinite(w.lat); }).map(function(w){ return w.lat; });
  var lons = withCoords.filter(function(w){ return Number.isFinite(w.lon); }).map(function(w){ return w.lon; });

  // If not enough coordinates, return grid fallback
  if (lats.length < 2 || lons.length < 2) {
    var cols = Math.ceil(Math.sqrt(_selectedSites.length));
    var out = {};
    _selectedSites.forEach(function(s, i) {
      out[s.site_id] = {
        tx: PAD_X + (i % cols) * ((W - 2*PAD_X) / Math.max(cols-1, 1)),
        ty: PAD_Y + Math.floor(i / cols) * 150,
      };
    });
    return out;
  }

  var minLat = Math.min.apply(null, lats), maxLat = Math.max.apply(null, lats);
  var minLon = Math.min.apply(null, lons), maxLon = Math.max.apply(null, lons);
  var lr = maxLat - minLat || 0.3, lonr = maxLon - minLon || 0.3;
  // Expand bounds 15% so edge nodes have breathing room
  minLat -= lr * 0.15;   maxLat += lr * 0.15;
  minLon -= lonr * 0.15; maxLon += lonr * 0.15;

  var out = {};
  withCoords.forEach(function(w) {
    out[w.id] = {
      tx: Number.isFinite(w.lon)
          ? PAD_X + (w.lon - minLon) / (maxLon - minLon) * (W - 2*PAD_X)
          : W / 2,
      // Flip: higher lat (north) → smaller y (top of screen)
      ty: Number.isFinite(w.lat)
          ? (H - PAD_Y) - (w.lat - minLat) / (maxLat - minLat) * (H - 2*PAD_Y)
          : H / 2,
    };
  });
  return out;
}

// ── Sync node list in-place ───────────────────────────────────────────────────
// Preserves x/y for nodes that are already on screen.
// New nodes start at their geographic target. Removed nodes are dropped.
// Always recomputes targets for all nodes (canvas resize + selection change).
function syncNodes(W, H) {
  var targets = computeGeoTargets(W, H);
  var selectedIds = _selectedSites.map(function(s){ return s.site_id; });

  // Drop deselected nodes
  _d3Nodes = _d3Nodes.filter(function(n){ return selectedIds.includes(n.id); });

  selectedIds.forEach(function(sid) {
    var t = targets[sid];
    var sel = _selectedSites.find(function(s){ return s.site_id === sid; });
    var full = SITES.find(function(f){ return f.site_id === sid; }) || {};
    var existing = _d3Nodes.find(function(n){ return n.id === sid; });

    if (existing) {
      // Update target and readings; keep current x/y
      existing.targetX  = t.tx;
      existing.targetY  = t.ty;
      existing.readings = _readings[sid] || [];
      existing.color    = sel.color;
    } else {
      // Brand-new node: start at geographic target
      _d3Nodes.push({
        id:       sid,
        name:     sel.name,
        color:    sel.color,
        siteType: (full.type || 'river').toLowerCase(),
        readings: _readings[sid] || [],
        targetX:  t.tx,
        targetY:  t.ty,
        x:        t.tx,
        y:        t.ty,
        vx: 0, vy: 0,
      });
    }
  });
}

// ── Effective connections for a given selection ───────────────────────────────
// After transitive reduction, A→C may not exist in the DB because A→B→C does.
// When B is NOT selected (e.g. only CWMS dams are selected, USGS gauges are not),
// we still need to show A→C. This BFS bridges through unselected intermediate nodes.
function effectiveConnections(selectedIds) {
  if (!selectedIds.length) return [];
  var selectedSet = new Set(selectedIds);

  // Build full directed adjacency from ALL stored connections
  var adj = {};
  _connections.forEach(function(c) {
    if (!adj[c.from_site_id]) adj[c.from_site_id] = [];
    adj[c.from_site_id].push(c.to_site_id);
  });

  var result = [];
  selectedIds.forEach(function(fromId) {
    var seen  = new Set([fromId]);
    var queue = [];
    (adj[fromId] || []).forEach(function(n) {
      if (!seen.has(n)) { seen.add(n); queue.push(n); }
    });
    while (queue.length) {
      var cur = queue.shift();
      if (selectedSet.has(cur)) {
        // Reached another selected site — emit effective edge
        result.push({ from_site_id: fromId, to_site_id: cur, bridged: !_connections.some(function(c){ return c.from_site_id===fromId && c.to_site_id===cur; }) });
      } else {
        // Unselected intermediate — keep walking downstream
        (adj[cur] || []).forEach(function(n) {
          if (!seen.has(n)) { seen.add(n); queue.push(n); }
        });
      }
    }
  });
  return result;
}

// ── Build link data ───────────────────────────────────────────────────────────
function buildLinks() {
  var selectedIds = _selectedSites.map(function(s){ return s.site_id; });
  _d3Links = effectiveConnections(selectedIds)
    .map(function(c) {
      var src = _d3Nodes.find(function(n){ return n.id === c.from_site_id; });
      var tgt = _d3Nodes.find(function(n){ return n.id === c.to_site_id; });
      if (!src || !tgt) return null;

      var upReadings = _readings[c.from_site_id] || [];
      var dnReadings = _readings[c.to_site_id]   || [];
      var fs = SITES.find(function(s){ return s.site_id === c.from_site_id; }) || {};
      var ts = SITES.find(function(s){ return s.site_id === c.to_site_id;   }) || {};
      var distKm = haversineKm(fs.latitude, fs.longitude, ts.latitude, ts.longitude);

      // ── Line thickness: discharge if available, else 2.5 ──────────────────
      var qUp  = upReadings.find(function(r){ return r.param_code === '00060'; }) || {};
      var qDn  = dnReadings.find(function(r){ return r.param_code === '00060'; }) || {};
      var thick = qUp.value ? Math.max(2, Math.min(10, 1.5 + Math.log10(qUp.value+1)*2.2)) : 2.5;

      // ── Color: always matches the from-node accent ─────────────────────────
      var color = _nodeColor(c.from_site_id);

      // ── Link label: show best available active parameter ───────────────────
      // Priority: discharge → gage height → CWMS flow/pool → temperature → DO → pH → first reading
      var PARAM_PRIORITY = ['00060','00065','Flow','Flow-Out','Flow-In','Elev-Pool','Elev-Tail','Stor','00010','00300','00400'];
      var activeCodes = (_selectedParams || []).map(function(p){ return p.code; });
      var labelParam = null;

      // Find highest-priority param that is both active and has upstream data
      for (var pi = 0; pi < PARAM_PRIORITY.length; pi++) {
        var code = PARAM_PRIORITY[pi];
        if (!activeCodes.length || activeCodes.includes(code)) {
          var r = upReadings.find(function(r){ return r.param_code === code; });
          if (r && r.value != null) { labelParam = r; break; }
        }
      }
      // Fallback: any reading with a value
      if (!labelParam) {
        labelParam = upReadings.find(function(r){ return r.value != null; }) || null;
      }

      var flowLbl = '';
      var pct     = null;
      if (labelParam) {
        var ti   = labelParam.trend === 'rising' ? '↑' : labelParam.trend === 'falling' ? '↓' : '→';
        var val  = labelParam.value;
        var unit = labelParam.unit || '';
        // Compact value formatting
        var valStr = (labelParam.param_code === '00060' && val >= 1000)
          ? (val/1000).toFixed(1)+'k'
          : (Number.isInteger(val) ? val : val.toFixed(1));
        flowLbl = valStr + ' ' + unit + ' ' + ti;

        // Confluence % only meaningful for discharge
        if (labelParam.param_code === '00060' && qDn.value) {
          pct = Math.round(val / qDn.value * 100);
        }
        // Delta for quality params (upstream vs downstream)
        if (['00010','00300','00400'].includes(labelParam.param_code)) {
          var dnParam = dnReadings.find(function(r){ return r.param_code === labelParam.param_code; });
          if (dnParam && dnParam.value != null) {
            var delta = (val - dnParam.value);
            var sign  = delta > 0 ? '+' : '';
            flowLbl += '  Δ' + sign + delta.toFixed(1);
          }
        }
      }

      return { source: src, target: tgt, thick, color,
               flowLabel: flowLbl, distLabel: distKm ? Math.round(distKm)+' km' : '', pct };
    })
    .filter(Boolean);
}

// ── Bezier path helpers ───────────────────────────────────────────────────────
function bezierPath(src, tgt) {
  var sh = NODE_H, th = NODE_H;
  var sx = src.x, sy = src.y + sh/2;   // exit: bottom port of source
  var tx = tgt.x, ty = tgt.y - th/2;  // enter: top port of target
  var dy = Math.abs(ty - sy), dx = Math.abs(tx - sx);
  var ctrl = Math.max(dy * 0.45, dx * 0.3, 55);
  return 'M '+f(sx)+' '+f(sy)+' C '+f(sx)+' '+f(sy+ctrl)+' '+f(tx)+' '+f(ty-ctrl)+' '+f(tx)+' '+f(ty);
}
function f(n) { return n.toFixed(1); }
function linkMidX(d) { return (d.source.x + d.target.x) / 2; }
function linkMidY(d) {
  return (d.source.y + NODE_H/2 + d.target.y - NODE_H/2) / 2;
}

// ── SVG render ────────────────────────────────────────────────────────────────
function renderSvg(W, H) {
  var svg = d3.select('#network-svg');
  svg.selectAll('*').remove();
  svg.attr('viewBox', '0 0 '+W+' '+H).attr('height', H);
  if (!_d3Nodes.length) return;

  svg.append('defs').html(`
    <marker id="arr-stable"  viewBox="0 -5 10 10" refX="9" refY="0" markerWidth="5" markerHeight="5" orient="auto"><path d="M0,-4L10,0L0,4" fill="#64748b"/></marker>
    <marker id="arr-rising"  viewBox="0 -5 10 10" refX="9" refY="0" markerWidth="5" markerHeight="5" orient="auto"><path d="M0,-4L10,0L0,4" fill="#38bdf8"/></marker>
    <marker id="arr-falling" viewBox="0 -5 10 10" refX="9" refY="0" markerWidth="5" markerHeight="5" orient="auto"><path d="M0,-4L10,0L0,4" fill="#fb923c"/></marker>
    <filter id="glow" x="-30%" y="-30%" width="160%" height="160%">
      <feGaussianBlur stdDeviation="3" result="blur"/>
      <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>
  `);

  var linkG = svg.append('g').attr('class', 'links');
  var nodeG = svg.append('g').attr('class', 'nodes');

  var linkSel = linkG.selectAll('.link-group').data(_d3Links).enter().append('g').attr('class', 'link-group');

  linkSel.append('path').attr('class','link-halo')
    .attr('stroke', function(d){ return d.color; }).attr('stroke-width', function(d){ return d.thick+10; })
    .attr('stroke-opacity', 0.08).attr('d', function(d){ return bezierPath(d.source, d.target); });

  linkSel.append('path').attr('class','link-path')
    .attr('stroke', function(d){ return d.color; }).attr('stroke-width', function(d){ return d.thick; })
    .attr('stroke-opacity', 0.9).attr('fill','none')
    .attr('marker-end', function(d){
      return d.color==='#38bdf8' ? 'url(#arr-rising)' : d.color==='#fb923c' ? 'url(#arr-falling)' : 'url(#arr-stable)';
    })
    .attr('d', function(d){ return bezierPath(d.source, d.target); });

  linkSel.append('text').attr('class','link-label lbl-flow').attr('text-anchor','middle')
    .attr('fill', function(d){ return d.color; }).attr('font-size','10px').attr('font-weight','600')
    .attr('x', linkMidX).attr('y', function(d){ return linkMidY(d)-7; })
    .text(function(d){ return d.flowLabel; });

  linkSel.append('text').attr('class','link-label lbl-dist').attr('text-anchor','middle')
    .attr('fill','#94a3b8').attr('font-size','9px')
    .attr('x', linkMidX).attr('y', function(d){ return linkMidY(d)+7; })
    .text(function(d){ return d.distLabel; });

  linkSel.append('text').attr('class','link-label lbl-pct').attr('text-anchor','middle')
    .attr('fill','#64748b').attr('font-size','8.5px')
    .attr('x', linkMidX).attr('y', function(d){ return linkMidY(d)+20; })
    .text(function(d){ return d.pct ? d.pct+'% of downstream' : ''; });

  var nodeSel = nodeG.selectAll('.node-group').data(_d3Nodes).enter()
    .append('g').attr('class','node-group')
    .attr('transform', function(d){ return 'translate('+d.x+','+d.y+')'; })
    .call(d3.drag()
      .on('start', function(event, d) {
        _dragMoved = false;
        _dragStartClient = event.sourceEvent ? { x: event.sourceEvent.clientX, y: event.sourceEvent.clientY } : null;
        if (!event.active) _simulation.alphaTarget(0.15).restart();
        d.fx = d.x; d.fy = d.y;
      })
      .on('drag', function(event, d) {
        _dragMoved = true;
        d.fx = event.x; d.fy = event.y;
      })
      .on('end', function(event, d) {
        // Measure pointer travel to distinguish click from drag
        var travelPx = 0;
        if (_dragStartClient && event.sourceEvent) {
          var dx = event.sourceEvent.clientX - _dragStartClient.x;
          var dy = event.sourceEvent.clientY - _dragStartClient.y;
          travelPx = Math.sqrt(dx*dx + dy*dy);
        }
        _dragStartClient = null;

        if (travelPx < 5) {
          // Treat as click — open slideover, don't scatter other nodes
          d.fx = null; d.fy = null;
          if (!event.active) _simulation.alphaTarget(0);
          openSlideover(d.id);
        } else {
          // Real drag — update anchor and redistribute
          d.targetX = d.fx; d.targetY = d.fy;
          d.fx = null; d.fy = null;
          if (!event.active) _simulation.alphaTarget(0).alpha(0.5).restart();
        }
      })
    );

  // Icon SVG paths (18×18 viewport)
  var ICON_PATHS = {
    river:     'M1 9 C4 5 7 13 11 9 C14 5 16 10 17 9',
    stream:    'M1 9 C4 5 7 13 11 9 C14 5 16 10 17 9',
    reservoir: 'M9 2 C5 2 2 6 2 10 a7 7 0 0 0 14 0 C16 6 13 2 9 2 Z',
    dam:       'M2 5 L16 5 L16 13 L2 13 Z M6 5 L6 13 M10 5 L10 13 M2 9 L6 9 M10 9 L16 9',
  };

  nodeSel.each(function(d) {
    var g       = d3.select(this);
    var isDam   = d.siteType === 'dam';
    var isRes   = d.siteType === 'reservoir';
    var accent  = isDam ? '#f97316' : isRes ? '#06b6d4' : d.color;
    var NW = NODE_W, NH = NODE_H, IW = ICON_W;
    var textX = -NW/2 + IW + 10;
    var primary = (d.readings||[]).find(function(r){ return r.param_code==='00060'; }) || (d.readings||[])[0];

    // Outer glow
    g.append('rect')
      .attr('x',-NW/2-3).attr('y',-NH/2-3).attr('width',NW+6).attr('height',NH+6)
      .attr('rx',10).attr('fill',accent).attr('opacity',0.1);

    // Card body
    g.append('rect').attr('class','node-body')
      .attr('x',-NW/2).attr('y',-NH/2).attr('width',NW).attr('height',NH)
      .attr('rx',7).attr('fill','#0d1f35').attr('stroke',accent).attr('stroke-width',1.5);

    // Icon panel background
    g.append('rect')
      .attr('x',-NW/2).attr('y',-NH/2).attr('width',IW).attr('height',NH)
      .attr('rx',7).attr('fill',accent).attr('opacity',0.13);
    // Square off the right side of the icon panel
    g.append('rect')
      .attr('x',-NW/2+IW-8).attr('y',-NH/2).attr('width',8).attr('height',NH)
      .attr('fill',accent).attr('opacity',0.13);

    // Left accent bar
    g.append('rect')
      .attr('x',-NW/2).attr('y',-NH/2).attr('width',3).attr('height',NH)
      .attr('rx',3).attr('fill',accent);

    // Divider
    g.append('line')
      .attr('x1',-NW/2+IW).attr('y1',-NH/2+4).attr('x2',-NW/2+IW).attr('y2',NH/2-4)
      .attr('stroke',accent).attr('stroke-width',0.5).attr('opacity',0.25);

    // Icon
    var iconPath = ICON_PATHS[d.siteType] || ICON_PATHS.river;
    g.append('path')
      .attr('d', iconPath)
      .attr('transform','translate('+(-NW/2+IW/2-9)+','+ (-9) +')')
      .attr('fill', isRes ? accent : 'none')
      .attr('fill-opacity', isRes ? 0.3 : 0)
      .attr('stroke', accent).attr('stroke-width', 1.8)
      .attr('stroke-linecap','round').attr('stroke-linejoin','round');

    // Site name
    g.append('text').attr('class','node-name')
      .attr('x', textX).attr('y', primary ? -6 : 4)
      .attr('fill','#e2e8f0').attr('font-size','11px').attr('font-weight','600')
      .attr('font-family','Inter,sans-serif')
      .text(truncate(d.name, 17));

    // Primary reading
    if (primary) {
      var ti = primary.trend==='rising'?'↑':primary.trend==='falling'?'↓':'→';
      var tc = primary.trend==='rising'?'#34d399':primary.trend==='falling'?'#f87171':'#64748b';
      var valStr = primary.value >= 1000
        ? (primary.value/1000).toFixed(1)+'k' : primary.value.toFixed(0);
      g.append('text')
        .attr('x', textX).attr('y', 10)
        .attr('fill',tc).attr('font-size','10px')
        .attr('font-family','JetBrains Mono,Courier New,monospace')
        .text(valStr+' '+primary.unit+' '+ti);
    }

    // Input port (top)
    g.append('circle').attr('cx',0).attr('cy',-NH/2)
      .attr('r',4).attr('fill','#0d1f35').attr('stroke',accent).attr('stroke-width',1.5);
    // Output port (bottom)
    g.append('circle').attr('cx',0).attr('cy',NH/2)
      .attr('r',4).attr('fill','#0d1f35').attr('stroke',accent).attr('stroke-width',1.5);
  });
}

// ── Force simulation ──────────────────────────────────────────────────────────
// Geographic anchor forces keep relative lat/lon relationships intact.
// Collision force spreads nodes so they don't overlap.
function runSimulation(W, H) {
  if (_simulation) _simulation.stop();

  _simulation = d3.forceSimulation(_d3Nodes)
    // Pull each node toward its geographic target
    .force('anchorX', d3.forceX(function(d){ return d.targetX; }).strength(0.08))
    .force('anchorY', d3.forceY(function(d){ return d.targetY; }).strength(0.08))
    // Prevent overlap — radius from half-diagonal of bounding box
    .force('collide', d3.forceCollide(collisionR).strength(0.85).iterations(3))
    .alphaDecay(0.018)
    .velocityDecay(0.45)
    .on('tick', function() {
      // Clamp to canvas bounds
      _d3Nodes.forEach(function(d) {
        d.x = Math.max(NODE_W/2+4, Math.min(W - NODE_W/2 - 4, d.x));
        d.y = Math.max(NODE_H/2+4, Math.min(H - NODE_H/2 - 4, d.y));
      });
      updatePositions();
    });
}

// ── Position update (simulation tick + drag) ──────────────────────────────────
function updatePositions() {
  d3.selectAll('.node-group').attr('transform', function(d){ return 'translate('+d.x+','+d.y+')'; });
  d3.selectAll('.link-path').attr('d', function(d){ return bezierPath(d.source, d.target); });
  d3.selectAll('.link-halo').attr('d', function(d){ return bezierPath(d.source, d.target); });
  d3.selectAll('.link-group').each(function(d) {
    var mx = linkMidX(d), my = linkMidY(d);
    d3.select(this).select('.lbl-flow').attr('x', mx).attr('y', my-7);
    d3.select(this).select('.lbl-dist').attr('x', mx).attr('y', my+7);
    d3.select(this).select('.lbl-pct' ).attr('x', mx).attr('y', my+20);
  });
}

// ── Canvas dimensions ─────────────────────────────────────────────────────────
function canvasSize() {
  var card = document.getElementById('canvas-card');
  var r    = card.getBoundingClientRect();
  return { W: r.width || 900, H: Math.max(r.height - 42, 300) }; // 42 = toolbar
}

// ── Main redraw entry point ───────────────────────────────────────────────────
function redrawNetwork() {
  if (_simulation) { _simulation.stop(); _simulation = null; }

  var cs = canvasSize();
  var W = cs.W, H = cs.H;

  syncNodes(W, H);
  buildLinks();
  renderSvg(W, H);
  if (_d3Nodes.length) runSimulation(W, H);
}

// ── Reset layout ──────────────────────────────────────────────────────────────
function resetLayout() {
  var cs = canvasSize();
  var W = cs.W, H = cs.H;
  var targets = computeGeoTargets(W, H);

  // Snap all nodes back to geographic targets and clear velocity
  _d3Nodes.forEach(function(d) {
    var t = targets[d.id];
    if (t) { d.targetX = t.tx; d.targetY = t.ty; d.x = t.tx; d.y = t.ty; }
    d.vx = 0; d.vy = 0;
    d.fx = null; d.fy = null;
  });

  renderSvg(W, H);
  if (_d3Nodes.length) runSimulation(W, H);
}

// ── Fullscreen ────────────────────────────────────────────────────────────────
function toggleFullscreen() {
  _fullscreen = !_fullscreen;
  var card  = document.getElementById('canvas-card');
  var label = document.getElementById('expand-label');
  card.classList.toggle('fn-fullscreen', _fullscreen);
  if (label) label.textContent = _fullscreen ? '✕' : '⛶';
  setTimeout(function() {
    if (_mapMode && _mlMap) _mlMap.resize();
    else redrawNetwork();
  }, 60);
}

// ── Map mode ──────────────────────────────────────────────────────────────────
function toggleMapMode() {
  _mapMode = !_mapMode;
  var svgEl  = document.getElementById('network-svg');
  var mapEl  = document.getElementById('map-view');
  var btn    = document.getElementById('mapToggleBtn');
  var rst    = document.getElementById('resetBtn');
  var hint   = document.getElementById('view-hint');

  var radarBtn = document.getElementById('radarToggleBtn');
  if (_mapMode) {
    svgEl.style.display = 'none';
    mapEl.style.display = 'block';
    btn.innerHTML = '⊕ Diagram';
    btn.style.color = '#0ea5e9';
    btn.style.borderColor = '#0ea5e9';
    if (rst)  rst.style.display = 'none';
    if (radarBtn) radarBtn.style.display = '';
    if (hint) hint.textContent = 'USGS National Map · NHDPlus hydrography · click markers for data';
    if (!_mlMap) _initMaplibreMap();
    else { _mlMap.resize(); renderMaplibreMap(); }
  } else {
    mapEl.style.display = 'none';
    svgEl.style.display = 'block';
    btn.innerHTML = '⊕ Map';
    btn.style.color = '';
    btn.style.borderColor = '';
    if (rst)  rst.style.display = '';
    if (radarBtn) radarBtn.style.display = 'none';
    if (hint) hint.textContent = 'Geographic lat/lon layout · drag nodes to adjust · topology from NLDI';
    _stopDashAnim();
    redrawNetwork();
  }
}

function _initMaplibreMap() {
  var mapEl = document.getElementById('map-view');
  _mlMap = new maplibregl.Map({
    container: mapEl,
    style: {
      version: 8,
      sources: {
        'usgs-topo': {
          type: 'raster',
          tiles: ['https://basemap.nationalmap.gov/arcgis/rest/services/USGSTopo/MapServer/tile/{z}/{y}/{x}'],
          tileSize: 256,
          attribution: 'USGS National Map',
          maxzoom: 16,
        },
      },
      layers: [{ id: 'usgs-topo', type: 'raster', source: 'usgs-topo' }],
    },
    center: [-122.5, 45.5],
    zoom: 7,
  });
  _mlMap.addControl(new maplibregl.NavigationControl(), 'top-right');
  _mlMap.on('load', function() {
    _mlMapReady = true;
    renderMaplibreMap();
  });
}

// ── Radar overlay toggle ──────────────────────────────────────────────────────
// RainViewer free tier (no API key) only serves tiles up to zoom 6.
// RV_TILE_MAXZOOM tells MapLibre to overzoom from z6 tiles rather than
// requesting z7+ tiles that return "Zoom Level Not Supported" images.
// RV_MAP_MAX is the map interaction limit — keeps the view in a range where
// the overzoomed tiles still look reasonable.
var RV_MIN_ZOOM      = 3;
var RV_MAP_MAX       = 8;
var RV_TILE_MAXZOOM  = 6;

async function toggleRadarLayer() {
  _radarOn = !_radarOn;
  var btn = document.getElementById('radarToggleBtn');
  if (_radarOn) {
    btn.style.color = '#38bdf8';
    btn.style.borderColor = '#0ea5e9';
    btn.textContent = '🌧 Radar ON';
    // Lock zoom BEFORE adding the source so MapLibre never requests out-of-range tiles
    _mlMap.setMinZoom(RV_MIN_ZOOM);
    _mlMap.setMaxZoom(RV_MAP_MAX);
    var cur = _mlMap.getZoom();
    if (cur > RV_MAP_MAX)       _mlMap.easeTo({ zoom: RV_MAP_MAX, duration: 400 });
    else if (cur < RV_MIN_ZOOM) _mlMap.easeTo({ zoom: RV_MIN_ZOOM, duration: 400 });
    await _addRadarLayer();
  } else {
    btn.style.color = '';
    btn.style.borderColor = '';
    btn.textContent = '🌧 Radar';
    _removeRadarLayer();
    _mlMap.setMinZoom(0);
    _mlMap.setMaxZoom(22);
  }
}

async function _addRadarLayer() {
  if (!_mlMap || !_mlMapReady) return;
  try {
    var r    = await fetch('https://api.rainviewer.com/public/weather-maps.json');
    var data = await r.json();
    _rvHost = data.host;
    var past = data.radar.past || [];
    if (!past.length) return;
    _rvLatestPath = past[past.length - 1].path;
    var tileUrl = _rvHost + _rvLatestPath + '/256/{z}/{x}/{y}/2/1_1.png';
    _removeRadarLayer();
    _mlMap.addSource('fn-radar', { type: 'raster', tiles: [tileUrl], tileSize: 256, maxzoom: RV_TILE_MAXZOOM, attribution: 'RainViewer' });
    _mlMap.addLayer({ id: 'fn-radar', type: 'raster', source: 'fn-radar', paint: { 'raster-opacity': 0.65 } });
  } catch(e) { console.warn('[Radar] Failed to load RainViewer:', e.message); }
}

function _removeRadarLayer() {
  if (!_mlMap) return;
  try { if (_mlMap.getLayer('fn-radar')) _mlMap.removeLayer('fn-radar'); } catch(_) {}
  try { if (_mlMap.getSource('fn-radar')) _mlMap.removeSource('fn-radar'); } catch(_) {}
}

// Returns compass bearing (degrees clockwise from north) between two lat/lon points
function mapBearing(lat1, lon1, lat2, lon2) {
  var φ1 = lat1 * Math.PI/180, φ2 = lat2 * Math.PI/180;
  var Δλ = (lon2 - lon1) * Math.PI/180;
  var y = Math.sin(Δλ) * Math.cos(φ2);
  var x = Math.cos(φ1)*Math.sin(φ2) - Math.sin(φ1)*Math.cos(φ2)*Math.cos(Δλ);
  return (Math.atan2(y, x) * 180/Math.PI + 360) % 360;
}

// ── Waterway path loading — served from server-side cache ────────────────────
// Paths are pre-computed by the server (services/waterways.js) and stored in
// the DB. The browser just fetches them; no Overpass queries from the client.
// If a pair is still pending (server crawl in progress) we poll every 15s.

var _OVERPASS_MIRRORS = [  // kept for potential manual fallback only
  'https://overpass-api.de/api/interpreter',
  'https://overpass.kumi.systems/api/interpreter',
  'https://maps.mail.ru/osm/tools/overpass/api/interpreter',
  'https://overpass.openstreetmap.ru/cgi/interpreter',
];

// Shared graph cache keyed by sorted site-ID string so re-renders with the
// same selection skip the crawl entirely.
var _waterwayGraphCache = null; // { key: string, nodes: Map }

function _sleep(ms) { return new Promise(function(r){ setTimeout(r, ms); }); }

// POST to Overpass with mirror rotation + 3-attempt retry on full-round failure.
// A 429 or 504 on one mirror tries the next; if all fail, wait 3 s and retry.
async function _postQL(ql) {
  var body = 'data=' + encodeURIComponent(ql);
  var RETRIES = 3, RETRY_DELAY = 3000;

  for (var attempt = 0; attempt < RETRIES; attempt++) {
    for (var i = 0; i < _OVERPASS_MIRRORS.length; i++) {
      try {
        var resp = await fetch(_OVERPASS_MIRRORS[i], {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: body,
          signal: AbortSignal.timeout ? AbortSignal.timeout(60000) : undefined,
        });
        if (resp.ok) return resp.json();
        console.warn('[Flowlines] mirror', i, 'HTTP', resp.status, '(attempt', attempt+1+')');
      } catch(e) {
        console.warn('[Flowlines] mirror', i, ':', e.message, '(attempt', attempt+1+')');
      }
    }
    if (attempt < RETRIES - 1) {
      console.warn('[Flowlines] all mirrors failed, waiting', RETRY_DELAY/1000, 's before retry…');
      await _sleep(RETRY_DELAY);
    }
  }
  throw new Error('all Overpass mirrors failed after ' + RETRIES + ' attempts');
}

// Exact QL from FlowNet._ql_seedDiscover (out skel qt gives nodes array on ways)
function _ql_seed(lat, lon, seedM) {
  return '[out:json][timeout:120];'
    + '('
    + '  way(around:' + seedM + ',' + lat + ',' + lon + ')'
    + '   ["waterway"~"^(river|canal|stream)$"]["intermittent"!="yes"]["name"];'
    + ')->.w0;'
    + 'node(w.w0)->.n0;'
    + '.w0 out skel qt;'
    + '>;  out skel qt;';
}

// Exact QL from FlowNet._ql_expandFromNodes
function _ql_expand(nodeIds, rx) {
  return '[out:json][timeout:120];'
    + 'node(id:' + nodeIds.join(',') + ')->.front;'
    + 'way(bn.front)'
    + '  ["waterway"~"' + rx + '"]["intermittent"!="yes"]->.wk;'
    + '.wk out skel qt;'
    + '>;  out skel qt;';
}

function _fnChunk(arr, n) {
  var out = [];
  for (var i = 0; i < arr.length; i += n) out.push(arr.slice(i, i + n));
  return out;
}

// Turn raw merged OSM elements into a directed node→node graph.
function _buildFlowGraph(osm) {
  var nodes = new Map();
  var els = osm.elements || [];
  var i, el;
  for (i = 0; i < els.length; i++) {
    el = els[i];
    if (el.type === 'node') nodes.set(el.id, { id:el.id, lat:el.lat, lon:el.lon, out:new Map() });
  }
  for (i = 0; i < els.length; i++) {
    el = els[i];
    if (el.type !== 'way' || !Array.isArray(el.nodes) || el.nodes.length < 2) continue;
    for (var j = 0; j < el.nodes.length - 1; j++) {
      var a = nodes.get(el.nodes[j]);
      var b = nodes.get(el.nodes[j + 1]);
      if (!a || !b) continue;
      var w = _geoDistM(a.lat, a.lon, b.lat, b.lon);
      if (!a.out.has(b.id) || w < a.out.get(b.id)) a.out.set(b.id, w);
    }
  }
  return nodes;
}

function _snapNode(nodes, lat, lon, maxM) {
  var bestId = null, bestD = Infinity;
  nodes.forEach(function(n) {
    var d = _geoDistM(lat, lon, n.lat, n.lon);
    if (d < bestD) { bestD = d; bestId = n.id; }
  });
  return bestD <= maxM ? bestId : null;
}

// Dijkstra on directed graph — returns node-ID array or null.
function _dijkstraPath(nodes, startId, goalId) {
  if (startId === null || goalId === null) return null;
  var dist = new Map([[startId, 0]]);
  var prev = new Map();
  var Q    = [{ id:startId, d:0 }];
  while (Q.length) {
    Q.sort(function(a, b) { return a.d - b.d; });
    var u = Q.shift();
    if (u.id === goalId) break;
    var uNode = nodes.get(u.id);
    if (!uNode) continue;
    uNode.out.forEach(function(w, vid) {
      var alt = (dist.get(u.id) || 0) + w;
      if (alt < (dist.has(vid) ? dist.get(vid) : Infinity)) {
        dist.set(vid, alt);
        prev.set(vid, u.id);
        Q.push({ id:vid, d:alt });
      }
    });
  }
  if (!prev.has(goalId) && startId !== goalId) return null;
  var path = [goalId];
  for (var c = goalId; c !== startId;) {
    var p = prev.get(c);
    if (p === undefined) return null;
    path.push(p); c = p;
  }
  path.reverse();
  return path;
}

function _geoDistM(lat1, lon1, lat2, lon2) {
  var R = 6371000, r = Math.PI / 180;
  var dLat = (lat2-lat1)*r, dLon = (lon2-lon1)*r;
  var a = Math.sin(dLat/2)*Math.sin(dLat/2)
        + Math.cos(lat1*r)*Math.cos(lat2*r)*Math.sin(dLon/2)*Math.sin(dLon/2);
  return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
}

// ── ONE shared crawl for all active sites ────────────────────────────────────
// Returns a Promise<Map> (the directed graph) cached by site-key.
// Exact crawl pattern from FlowNet.submitOverpassQuery iterative path.
async function _buildSharedWaterwayGraph(sites) {
  var cacheKey = sites.map(function(s){ return s.site_id; }).sort().join('|');
  if (_waterwayGraphCache && _waterwayGraphCache.key === cacheKey) {
    console.log('[Flowlines] using cached graph for', cacheKey);
    return _waterwayGraphCache.nodes;
  }

  var cfg = {
    seedM:     8600,
    hops:      20,
    rx:        '^(river|stream|canal|drain|ditch)$',
    batchSize: 4000,
    sleepMs:   150,
  };

  // bbox padded 25 km around all sites
  var PAD_KM = 25;
  var lats = sites.map(function(s){ return s.latitude; });
  var lons = sites.map(function(s){ return s.longitude; });
  var midLat = (Math.min.apply(null, lats) + Math.max.apply(null, lats)) / 2;
  var padLat = PAD_KM / 111.32;
  var padLon = PAD_KM / (111.32 * Math.cos(midLat * Math.PI / 180));
  var bbox = {
    s: Math.min.apply(null, lats) - padLat,
    n: Math.max.apply(null, lats) + padLat,
    w: Math.min.apply(null, lons) - padLon,
    e: Math.max.apply(null, lons) + padLon,
  };
  var inBBox = function(lat, lon) {
    return lat >= bbox.s && lat <= bbox.n && lon >= bbox.w && lon <= bbox.e;
  };

  var seenNode = new Set();
  var seenWay  = new Set();
  var elements = [];

  // Crawl each site sequentially — exact FlowNet crawlNextSeed pattern
  for (var si = 0; si < sites.length; si++) {
    var site = sites[si];
    console.log('[Flowlines] seed', si+1, '/', sites.length, '—', site.site_id);

    // Seed query
    var r0    = await _postQL(_ql_seed(site.latitude, site.longitude, cfg.seedM));
    var ways0 = (r0.elements || []).filter(function(e){ return e.type === 'way'; });
    var nds0  = (r0.elements || []).filter(function(e){ return e.type === 'node'; });
    var nMap0 = new Map(nds0.map(function(n){ return [n.id, n]; }));
    var frontier = new Set();

    ways0.forEach(function(w) {
      if (seenWay.has(w.id)) return;
      var ok = (w.nodes||[]).some(function(nid){ var n=nMap0.get(nid); return n && inBBox(n.lat,n.lon); });
      if (!ok) return;
      seenWay.add(w.id);
      elements.push({ type:'way', id:w.id, nodes:w.nodes });
      (w.nodes||[]).forEach(function(nid) {
        var n = nMap0.get(nid); if (!n) return;
        if (!seenNode.has(n.id)) { seenNode.add(n.id); elements.push({ type:'node', id:n.id, lat:n.lat, lon:n.lon }); }
        if (inBBox(n.lat, n.lon)) frontier.add(n.id);
      });
    });

    // Hop expansion — exact FlowNet expandHop / runBatch pattern
    for (var hop = 0; hop < cfg.hops && frontier.size > 0; hop++) {
      var ids     = Array.from(frontier);
      frontier    = new Set();
      var batches = _fnChunk(ids, cfg.batchSize);

      for (var bi = 0; bi < batches.length; bi++) {
        await _sleep(cfg.sleepMs);
        var rk    = await _postQL(_ql_expand(batches[bi], cfg.rx));
        var wsk   = (rk.elements||[]).filter(function(e){ return e.type==='way'; });
        var nsk   = (rk.elements||[]).filter(function(e){ return e.type==='node'; });
        var nMapK = new Map(nsk.map(function(n){ return [n.id, n]; }));

        wsk.forEach(function(w) {
          if (seenWay.has(w.id)) return;
          var ok = (w.nodes||[]).some(function(nid){ var n=nMapK.get(nid); return n && inBBox(n.lat,n.lon); });
          if (!ok) return;
          seenWay.add(w.id);
          elements.push({ type:'way', id:w.id, nodes:w.nodes });
          (w.nodes||[]).forEach(function(nid) {
            var n = nMapK.get(nid); if (!n) return;
            if (!seenNode.has(n.id)) { seenNode.add(n.id); elements.push({ type:'node', id:n.id, lat:n.lat, lon:n.lon }); }
            if (inBBox(n.lat, n.lon)) frontier.add(n.id);
          });
        });
      }
    }
    // sleep before next seed (polite pacing, matches FlowNet nap between seeds)
    await _sleep(cfg.sleepMs);
  }

  console.log('[Flowlines] crawl done — ways:', seenWay.size, 'nodes:', seenNode.size);
  var nodes = _buildFlowGraph({ elements: elements });
  console.log('[Flowlines] graph nodes:', nodes.size);
  _waterwayGraphCache = { key: cacheKey, nodes: nodes };
  return nodes;
}

// Derive [[lat,lon],...] path for one pair from the shared graph.
// Tries both directions (handles tributary→upstream-mainstem).
function _pairFlowline(nodes, fromSite, toSite) {
  var SNAP_MAX = 30000;
  var fromNode = _snapNode(nodes, fromSite.latitude, fromSite.longitude, SNAP_MAX);
  var toNode   = _snapNode(nodes, toSite.latitude,   toSite.longitude,   SNAP_MAX);
  if (!fromNode || !toNode) return null;
  var path = _dijkstraPath(nodes, fromNode, toNode)
          || _dijkstraPath(nodes, toNode,   fromNode);
  if (!path || path.length < 2) return null;
  return path.map(function(id) { var n = nodes.get(id); return [n.lat, n.lon]; });
}

// Place a directional arrow + optional discharge label along a polyline path.
// latlngs = [[lat,lon],...].
// Arrow sits on the line; label is a SEPARATE marker offset perpendicular to
// the flow direction (right side of bearing) so it never overlaps the waterway
// or the permanent site-name labels at the endpoints.
function _addFlowArrow(latlngs, color, upQ, token) {
  if (_mapRenderToken !== token) return;
  var mid    = Math.floor(latlngs.length / 2);
  var p1     = latlngs[Math.max(mid - 1, 0)];
  var p2     = latlngs[Math.min(mid, latlngs.length - 1)];
  var bear   = mapBearing(p1[0], p1[1], p2[0], p2[1]);
  var lngLat = [latlngs[mid][1], latlngs[mid][0]];

  // ── Arrow — centered exactly on the waterway line ─────────────────────────
  var arrowEl = document.createElement('div');
  arrowEl.style.cssText = 'pointer-events:none;width:22px;height:22px;';
  arrowEl.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 22 22"'
    + ' style="display:block;transform:rotate(' + bear.toFixed(1) + 'deg);transform-origin:11px 11px;">'
    + '<polygon points="11,2 19,17 11,12 3,17" fill="' + color + '" opacity="0.95"/>'
    + '<polygon points="11,2 19,17 11,12 3,17" fill="none" stroke="rgba(8,18,32,0.7)"'
    + ' stroke-width="1.5" stroke-linejoin="round"/>'
    + '</svg>';
  var am = new maplibregl.Marker({ element: arrowEl, anchor: 'center' })
    .setLngLat(lngLat).addTo(_mlMap);
  _mlMarkers.push(am);

  // ── Label — perpendicular offset, right side of flow direction ────────────
  // Perpendicular-right of bearing θ in screen coords (x=right, y=down):
  //   offset = [ cos(θ_rad), sin(θ_rad) ] × PERP_PX
  // Verified: N→+x(east), E→+y(south), S→-x(west), W→-y(north)
  if (upQ && upQ.value) {
    var ti  = upQ.trend === 'rising' ? '↑' : upQ.trend === 'falling' ? '↓' : '→';
    var lbl = (upQ.value >= 1000 ? (upQ.value / 1000).toFixed(1) + 'k' : Math.round(upQ.value))
            + (upQ.unit && upQ.unit !== 'ft³/s' && upQ.unit !== 'cfs' ? ' ' + upQ.unit : ' cfs')
            + ' ' + ti;

    var rad  = bear * Math.PI / 180;
    var PERP = 24; // px — enough clearance from a 3.5px line + arrow
    var ox   = Math.cos(rad) * PERP;
    var oy   = Math.sin(rad) * PERP;

    var lblEl = document.createElement('div');
    lblEl.style.cssText = 'pointer-events:none;white-space:nowrap;'
      + 'font-family:JetBrains Mono,monospace;font-size:10px;font-weight:700;'
      + 'color:' + color + ';background:rgba(8,18,32,0.88);'
      + 'border:1.5px solid ' + color + ';padding:2px 7px;border-radius:4px;'
      + 'box-shadow:0 1px 4px rgba(0,0,0,0.5);';
    lblEl.textContent = lbl;

    var lm = new maplibregl.Marker({ element: lblEl, anchor: 'center', offset: [ox, oy] })
      .setLngLat(lngLat).addTo(_mlMap);
    _mlMarkers.push(lm);
  }
}

// Returns the accent color for a site — matches the node card color in the diagram.
// DAMs are always orange, reservoirs cyan, rivers use the chip palette color.
function _nodeColor(siteId) {
  var full = SITES.find(function(s){ return s.site_id === siteId; }) || {};
  var type = (full.type || 'river').toLowerCase();
  if (type === 'dam')       return '#f97316';
  if (type === 'reservoir') return '#06b6d4';
  var sel = _selectedSites.find(function(s){ return s.site_id === siteId; });
  return sel ? sel.color : '#64748b';
}

function renderMaplibreMap() {
  var token = ++_mapRenderToken;
  if (!_mlMap) return;

  // Sources/layers are created in _initMaplibreMap's 'load' handler.
  // If that hasn't fired yet, bail — the load handler will call us.
  if (!_mlMapReady) return;

  // Stop any running dash animation and clear markers/popups
  _stopDashAnim();
  _mlMarkers.forEach(function(m) { m.remove(); });
  _mlMarkers = [];
  _mlPopups.forEach(function(p) { p.remove(); });
  _mlPopups = [];

  // Remove previously added GeoJSON sources/layers (all three speed tiers + base layers)
  ['ww-line-fast','ww-shadow-fast','ww-line','ww-shadow','ww-line-slow','ww-shadow-slow',
   'conn-placeholder','conn-inactive'].forEach(function(id) {
    if (_mlMap.getLayer(id)) _mlMap.removeLayer(id);
    if (_mlMap.getSource(id)) _mlMap.removeSource(id);
  });
  // Remove basin polygon layers from previous render
  _mlBasinLayers.forEach(function(ids) {
    if (_mlMap.getLayer(ids.outline)) _mlMap.removeLayer(ids.outline);
    if (_mlMap.getLayer(ids.fill))    _mlMap.removeLayer(ids.fill);
    if (_mlMap.getSource(ids.src))    _mlMap.removeSource(ids.src);
  });
  _mlBasinLayers = [];
  _setFlowlineStatus(null);

  var selectedIds = _selectedSites.map(function(s){ return s.site_id; });
  var boundsCoords = [];

  // ── Basin polygon overlays (drawn first so they sit below all other layers) ─
  _fnActiveBasins.forEach(function(basin) {
    var srcId     = 'basin-src-'  + basin.code;
    var fillId    = 'basin-fill-' + basin.code;
    var outlineId = 'basin-ol-'   + basin.code;
    var renderTok = token;
    fetch('/api/basins/' + basin.code + '/polygon')
      .then(function(r) { return r.json(); })
      .then(function(json) {
        if (renderTok !== _mapRenderToken) return;
        if (!json.feature) return;
        if (_mlMap.getSource(srcId)) return;
        _mlMap.addSource(srcId, { type: 'geojson', data: json.feature });
        _mlMap.addLayer({ id: fillId, type: 'fill', source: srcId,
          paint: { 'fill-color': basin.color, 'fill-opacity': 0.18 } });
        _mlMap.addLayer({ id: outlineId, type: 'line', source: srcId,
          paint: { 'line-color': basin.color, 'line-width': 3, 'line-opacity': 0.9 } });
        _mlBasinLayers.push({ src: srcId, fill: fillId, outline: outlineId });
      })
      .catch(function() {});
  });

  // effectiveConns = direct + bridged connections between selected sites
  var effectiveConns = effectiveConnections(selectedIds);

  // ── Inactive connection lines (faint dashed) — direct edges to unselected sites ──
  var inactiveFeatures = [];
  _connections.forEach(function(c) {
    if (selectedIds.includes(c.from_site_id) && selectedIds.includes(c.to_site_id)) return;
    var from = SITES.find(function(s){ return s.site_id === c.from_site_id; });
    var to   = SITES.find(function(s){ return s.site_id === c.to_site_id; });
    if (!from || !to || !from.latitude || !to.latitude) return;
    inactiveFeatures.push({ type:'Feature', geometry:{ type:'LineString',
      coordinates:[[from.longitude,from.latitude],[to.longitude,to.latitude]] } });
  });
  _mlMap.addSource('conn-inactive', { type:'geojson', data:{ type:'FeatureCollection', features:inactiveFeatures } });
  _mlMap.addLayer({ id:'conn-inactive', type:'line', source:'conn-inactive',
    paint:{ 'line-color':'#94a3b8', 'line-width':1, 'line-opacity':0.3, 'line-dasharray':[5,6] } });

  // ── Active placeholder lines (colored dashed, replaced when waterways arrive) ──
  var activeConns = effectiveConns;
  var placeholderFeatures = [];
  activeConns.forEach(function(c) {
    var from = SITES.find(function(s){ return s.site_id === c.from_site_id; });
    var to   = SITES.find(function(s){ return s.site_id === c.to_site_id; });
    if (!from || !to || !from.latitude || !to.latitude) return;
    var color = _nodeColor(c.from_site_id);
    placeholderFeatures.push({ type:'Feature',
      properties:{ key: c.from_site_id+'->'+c.to_site_id, color: color },
      geometry:{ type:'LineString', coordinates:[[from.longitude,from.latitude],[to.longitude,to.latitude]] } });
  });
  _mlMap.addSource('conn-placeholder', { type:'geojson', data:{ type:'FeatureCollection', features:placeholderFeatures } });
  _mlMap.addLayer({ id:'conn-placeholder', type:'line', source:'conn-placeholder',
    paint:{ 'line-color':['get','color'], 'line-width':2, 'line-opacity':0.55, 'line-dasharray':[8,6] } });

  // ── Waterway path sources — three speed tiers (empty until paths arrive) ────
  // slow=≤3000 cfs / normal=3–50k / fast=>50k — mirrors original CSS animation classes
  ['slow', 'normal', 'fast'].forEach(function(sp) {
    var shId = sp === 'normal' ? 'ww-shadow'   : 'ww-shadow-' + sp;
    var lnId = sp === 'normal' ? 'ww-line'     : 'ww-line-'   + sp;
    _mlMap.addSource(shId, { type:'geojson', data:{ type:'FeatureCollection', features:[] } });
    _mlMap.addLayer({ id:shId, type:'line', source:shId,
      paint:{ 'line-color':'#0a1628', 'line-width':6, 'line-opacity':0.22 } });
    _mlMap.addSource(lnId, { type:'geojson', data:{ type:'FeatureCollection', features:[] } });
    _mlMap.addLayer({ id:lnId, type:'line', source:lnId,
      paint:{ 'line-color':['get','color'], 'line-width':3.5, 'line-opacity':0.85,
              'line-dasharray': _DASH_SEQ[0] } });
  });

  // ── Site markers ──────────────────────────────────────────────────────────
  _selectedSites.forEach(function(s) {
    var full = SITES.find(function(f){ return f.site_id === s.site_id; }) || {};
    if (!full.latitude || !full.longitude) return;
    boundsCoords.push([full.longitude, full.latitude]);

    var isDam  = (full.type||'river').toLowerCase() === 'dam';
    var isRes  = (full.type||'river').toLowerCase() === 'reservoir';
    var isCwms = full.source === 'cwms';
    var accent = isDam ? '#f97316' : isRes ? '#06b6d4' : s.color;
    var readings = _readings[s.site_id] || [];
    var sz = isDam ? 24 : isRes ? 22 : 18;

    // ── Zero-size anchor wrapper — MapLibre anchors to the exact lat/lon ────────
    // Using a 0×0 wrapper prevents any label overflow or child CSS from
    // influencing the anchor-offset calculation MapLibre does via offsetWidth/Height.
    var half = sz / 2;
    var wrapper = document.createElement('div');
    wrapper.style.cssText = 'width:0;height:0;overflow:visible;cursor:pointer;';

    // Dot circle — absolutely centered on the anchor point
    var dot = document.createElement('div');
    dot.style.cssText = 'position:absolute;'
      + 'width:'+sz+'px;height:'+sz+'px;border-radius:50%;'
      + 'left:'+(-half)+'px;top:'+(-half)+'px;'
      + 'background:'+accent+';border:2.5px solid #0a1628;'
      + 'box-shadow:0 0 0 2px '+accent+'44;'
      + 'display:flex;align-items:center;justify-content:center;';
    if (isDam) dot.innerHTML = '<span style="font-size:6px;font-weight:800;color:#0a1628;letter-spacing:.02em;">DAM</span>';
    else if (isRes) dot.innerHTML = '<span style="font-size:6px;font-weight:800;color:#0a1628;letter-spacing:.02em;">RES</span>';
    else if (isCwms) dot.innerHTML = '<span style="font-size:7px;font-weight:800;color:#0a1628;">⬡</span>';
    wrapper.appendChild(dot);

    // Permanent name label — anchored to the same 0×0 point, shifted up above dot
    var typeTag = isDam ? ' · DAM' : isRes ? ' · RES' : '';
    var lbl = document.createElement('div');
    lbl.textContent = truncate(s.name, 22) + typeTag;
    lbl.style.cssText = 'position:absolute;left:0;top:0;'
      + 'transform:translate(-50%, calc(-100% - '+(half+4)+'px));'
      + 'background:rgba(8,18,32,0.92);border:1px solid rgba(255,255,255,0.15);border-radius:4px;'
      + 'color:#f1f5f9;font-size:10px;font-weight:600;padding:2px 7px;'
      + 'white-space:nowrap;pointer-events:none;font-family:Inter,sans-serif;';
    wrapper.appendChild(lbl);

    // Hover popup HTML
    var popupHtml = '<div style="font-family:Inter,sans-serif;min-width:170px;max-width:220px;">'
      + '<div style="font-weight:700;font-size:12px;margin-bottom:5px;color:#e2e8f0;">' + esc(s.name) + '</div>'
      + (isDam ? '<div style="font-size:9px;color:#fb923c;font-weight:700;letter-spacing:.06em;margin-bottom:4px;">DAM</div>'
               : isRes ? '<div style="font-size:9px;color:#22d3ee;font-weight:700;letter-spacing:.06em;margin-bottom:4px;">RESERVOIR</div>'
               : isCwms ? '<div style="font-size:9px;color:#f59e0b;font-weight:700;letter-spacing:.06em;margin-bottom:4px;">CWMS</div>' : '')
      + (readings.length
          ? readings.map(function(r) {
              var ti = r.trend==='rising'?'↑':r.trend==='falling'?'↓':'→';
              var tc = r.trend==='rising'?'#34d399':r.trend==='falling'?'#f87171':'#94a3b8';
              return '<div style="display:flex;justify-content:space-between;gap:12px;font-size:11px;margin-bottom:3px;">'
                + '<span style="color:#64748b;">'+esc(r.param_name)+'</span>'
                + '<span style="font-weight:600;color:'+tc+';">'+r.value.toFixed(1)+' '+esc(r.unit)+' '+ti+'</span>'
                + '</div>';
            }).join('')
          : '<div style="font-size:11px;color:#475569;">No data loaded</div>')
      + '<div style="margin-top:6px;padding-top:6px;border-top:1px solid #1e293b;font-size:9px;color:#334155;">Click for full details</div>'
      + '</div>';

    var popup = new maplibregl.Popup({ closeButton:false, offset:half + 4, maxWidth:'240px' })
      .setHTML(popupHtml);
    _mlPopups.push(popup);

    // anchor:'center' on a 0×0 element → no offset applied → wrapper sits exactly at lat/lon
    var marker = new maplibregl.Marker({ element: wrapper, anchor:'center' })
      .setLngLat([full.longitude, full.latitude])
      .addTo(_mlMap);
    _mlMarkers.push(marker);

    // Hover: open/close popup
    (function(mk, pp, sid) {
      mk.getElement().addEventListener('mouseenter', function() { pp.setLngLat(mk.getLngLat()).addTo(_mlMap); });
      mk.getElement().addEventListener('mouseleave', function() { pp.remove(); });
      mk.getElement().addEventListener('click',      function(e) { e.stopPropagation(); openSlideover(sid); });
    }(marker, popup, s.site_id));
  });

  // Fit map to selected sites
  if (boundsCoords.length > 1) {
    var lngs = boundsCoords.map(function(b){ return b[0]; });
    var lats = boundsCoords.map(function(b){ return b[1]; });
    _mlMap.fitBounds(
      [[Math.min.apply(null,lngs), Math.min.apply(null,lats)],
       [Math.max.apply(null,lngs), Math.max.apply(null,lats)]],
      { padding:80, maxZoom:13, duration:400 }
    );
  } else if (boundsCoords.length === 1) {
    _mlMap.easeTo({ center:boundsCoords[0], zoom:11, duration:400 });
  }

  if (!activeConns.length) return;
  _setFlowlineStatus('loading', activeConns.length);

  var activeSiteIds = [];
  activeConns.forEach(function(c) {
    if (activeSiteIds.indexOf(c.from_site_id) === -1) activeSiteIds.push(c.from_site_id);
    if (activeSiteIds.indexOf(c.to_site_id)   === -1) activeSiteIds.push(c.to_site_id);
  });

  function _drawWaterwayPaths(pathData) {
    if (token !== _mapRenderToken) { _setFlowlineStatus(null); return; }
    pathData = pathData.filter(function(entry) {
      return selectedIds.includes(entry.from_site_id) && selectedIds.includes(entry.to_site_id);
    });

    // Three speed buckets: slow=≤3000 cfs, normal=3–50k, fast=>50k
    var shadowBuckets = { slow:[], normal:[], fast:[] };
    var lineBuckets   = { slow:[], normal:[], fast:[] };
    var stillPending  = 0;
    var resolvedKeys  = {};

    pathData.forEach(function(entry) {
      // CWMS-aware discharge: try USGS 00060 first, then CWMS Flow params
      var upReadings = _readings[entry.from_site_id] || [];
      var upQ = upReadings.find(function(r){ return r.param_code==='00060'; })
             || upReadings.find(function(r){ return r.param_code==='Flow' || r.param_code==='Flow-Out'; })
             || {};
      var color = _nodeColor(entry.from_site_id);
      var qVal  = upQ && upQ.value ? upQ.value : 0;
      var sp    = qVal > 50000 ? 'fast' : qVal > 3000 ? 'normal' : 'slow';

      if (entry.status === 'pending') { stillPending++; return; }
      resolvedKeys[entry.from_site_id+'->'+entry.to_site_id] = true;

      var seg = (entry.status === 'ok' && entry.path && entry.path.length >= 2) ? entry.path : null;
      console.log('[Flowlines]', entry.from_site_id, '->', entry.to_site_id,
                  '|', entry.status, seg ? seg.length+' pts' : 'no path', '|', sp);

      if (seg) {
        // seg = [[lat,lon],...] — MapLibre wants [lng,lat]
        var coords = seg.map(function(pt){ return [pt[1], pt[0]]; });
        shadowBuckets[sp].push({ type:'Feature', geometry:{ type:'LineString', coordinates:coords } });
        lineBuckets[sp].push({ type:'Feature', properties:{ color:color },
          geometry:{ type:'LineString', coordinates:coords } });
        _addFlowArrow(seg, color, upQ, token);
      } else {
        var from = SITES.find(function(s){ return s.site_id === entry.from_site_id; });
        var to   = SITES.find(function(s){ return s.site_id === entry.to_site_id; });
        if (from && to && from.latitude && to.latitude) {
          var pts = [[from.latitude,from.longitude],[to.latitude,to.longitude]];
          lineBuckets[sp].push({ type:'Feature', properties:{ color:color },
            geometry:{ type:'LineString', coordinates:[[from.longitude,from.latitude],[to.longitude,to.latitude]] } });
          _addFlowArrow(pts, color, upQ, token);
        }
      }
    });

    // Push features into the three speed-tier sources
    ['slow', 'normal', 'fast'].forEach(function(sp) {
      var shId = sp === 'normal' ? 'ww-shadow'   : 'ww-shadow-' + sp;
      var lnId = sp === 'normal' ? 'ww-line'     : 'ww-line-'   + sp;
      if (_mlMap.getSource(shId)) _mlMap.getSource(shId).setData({ type:'FeatureCollection', features:shadowBuckets[sp] });
      if (_mlMap.getSource(lnId)) _mlMap.getSource(lnId).setData({ type:'FeatureCollection', features:lineBuckets[sp] });
    });

    // Start animation if any waterway lines are visible
    var hasLines = ['slow','normal','fast'].some(function(sp){ return lineBuckets[sp].length > 0; });
    if (hasLines) _startDashAnim();

    // Remove placeholder lines that now have real geometry
    if (_mlMap.getSource('conn-placeholder')) {
      var remaining = placeholderFeatures.filter(function(f){ return !resolvedKeys[f.properties.key]; });
      _mlMap.getSource('conn-placeholder').setData({ type:'FeatureCollection', features:remaining });
    }

    if (stillPending > 0) {
      _setFlowlineStatus('loading');
      setTimeout(function() {
        if (token !== _mapRenderToken) return;
        _fetchAndDrawWaterways();
      }, 15000);
    } else {
      _setFlowlineStatus('done');
    }
  }

  function _fetchAndDrawWaterways() {
    fetch('/api/connections/waterways?sites=' + activeSiteIds.join(','))
      .then(function(r){ return r.json(); })
      .then(function(json){ _drawWaterwayPaths(json.data || []); })
      .catch(function(err){
        console.error('[Flowlines] fetch failed:', err);
        if (token === _mapRenderToken) _setFlowlineStatus('done');
      });
  }

  _fetchAndDrawWaterways();
}

// Show/hide the "fetching waterways" pill inside the map
function _setFlowlineStatus(state, remaining) {
  var el = document.getElementById('flowline-status');
  if (!el) return;
  if (!state || state === 'done') {
    el.style.display = 'none';
  } else {
    el.style.display = 'flex';
    var txt = document.getElementById('flowline-status-text');
    if (txt) txt.textContent = remaining > 1
      ? 'Mapping waterways… (' + remaining + ' remaining)'
      : 'Mapping waterways…';
  }
}

// ── Slideover ─────────────────────────────────────────────────────────────────
var ICON_PATHS_SO = {
  river:     'M1 9 C4 5 7 13 11 9 C14 5 16 10 17 9',
  stream:    'M1 9 C4 5 7 13 11 9 C14 5 16 10 17 9',
  reservoir: 'M9 2 C5 2 2 6 2 10 a7 7 0 0 0 14 0 C16 6 13 2 9 2 Z',
  dam:       'M2 5 L16 5 L16 13 L2 13 Z M6 5 L6 13 M10 5 L10 13 M2 9 L6 9 M10 9 L16 9',
};

// ── Collapsible section state ──────────────────────────────────────────────────
var _soCollapsed = {};
try { _soCollapsed = JSON.parse(localStorage.getItem('so_collapsed') || '{}'); } catch(_) {}

function soToggle(id) {
  var body = document.getElementById('so-sect-' + id);
  var chev = document.getElementById('so-chev-' + id);
  if (!body) return;
  var nowHidden = body.style.display === 'none';
  body.style.display = nowHidden ? '' : 'none';
  if (chev) chev.style.transform = nowHidden ? 'rotate(0deg)' : 'rotate(-90deg)';
  _soCollapsed[id] = !nowHidden; // true = collapsed
  try { localStorage.setItem('so_collapsed', JSON.stringify(_soCollapsed)); } catch(_) {}
}

function _soMkSection(id, label, labelColor, bodyHtml, defaultOpen) {
  var open     = defaultOpen !== false && !_soCollapsed[id];
  var chevRot  = open ? 'rotate(0deg)' : 'rotate(-90deg)';
  var display  = open ? '' : 'none';
  var chevSvg  = '<svg id="so-chev-'+id+'" style="width:11px;height:11px;flex-shrink:0;transition:transform 0.2s;transform:'+chevRot+';color:#334155;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 9l-7 7-7-7"/></svg>';
  return '<div class="so-sect">'
    + '<div class="so-sect-hdr" onclick="soToggle(\''+id+'\')">'
    + '<span class="so-section-label"'+(labelColor?' style="color:'+labelColor+';"':'')+'>'+label+'</span>'
    + chevSvg
    + '</div>'
    + '<div class="so-sect-body" id="so-sect-'+id+'" style="display:'+display+';">'
    + bodyHtml
    + '</div>'
    + '</div>';
}

// Spinner placeholder while async sections load
function _soLoading() {
  return '<div class="so-async-ph"><svg style="width:11px;height:11px;animation:spin 1s linear infinite;color:#0ea5e9;" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" opacity=".25"/><path d="M12 2a10 10 0 0 1 10 10" stroke="currentColor" stroke-width="3" stroke-linecap="round"/></svg>loading…</div>';
}

// ── Sparkline SVG ──────────────────────────────────────────────────────────────
function _sparklineSvg(points, color, w, h) {
  var vals = (points || []).map(function(d){ return +d.value; }).filter(isFinite);
  if (vals.length < 2) return '<div style="font-size:10px;color:#334155;padding:6px 0;">no history</div>';
  var mn = Math.min.apply(null, vals), mx = Math.max.apply(null, vals), rng = mx - mn || 1;
  var toX = function(i){ return ((i / (vals.length-1)) * (w-4) + 2).toFixed(1); };
  var toY = function(v){ return ((h-4) - ((v-mn)/rng)*(h-8) + 4).toFixed(1); };
  var pts  = vals.map(function(v,i){ return toX(i)+','+toY(v); }).join(' ');
  var area = 'M2,'+(h-2)+' L'+vals.map(function(v,i){ return toX(i)+','+toY(v); }).join(' L')+' L'+(w-2)+','+(h-2)+' Z';
  var gid  = 'spkg'+color.replace(/[^a-z0-9]/gi,'');
  return '<svg width="'+w+'" height="'+h+'" viewBox="0 0 '+w+' '+h+'" style="display:block;overflow:visible;">'
    + '<defs><linearGradient id="'+gid+'" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="'+color+'" stop-opacity="0.3"/><stop offset="100%" stop-color="'+color+'" stop-opacity="0.02"/></linearGradient></defs>'
    + '<path d="'+area+'" fill="url(#'+gid+')"/>'
    + '<polyline points="'+pts+'" fill="none" stroke="'+color+'" stroke-width="1.5" stroke-linejoin="round" stroke-linecap="round"/>'
    + '</svg>';
}

// ── Anomaly: z-score against 7-day baseline ───────────────────────────────────
function _anomalyScore(histPoints, current) {
  var vals = (histPoints || []).map(function(d){ return +d.value; }).filter(isFinite);
  if (vals.length < 12 || current == null) return null;
  var mean = vals.reduce(function(a,b){ return a+b; },0) / vals.length;
  var std  = Math.sqrt(vals.reduce(function(a,b){ return a+Math.pow(b-mean,2); },0) / vals.length);
  var z    = std > 0 ? (current - mean) / std : 0;
  return { z: z, absZ: Math.abs(z), mean: mean, std: std, n: vals.length };
}

// ── Travel-time estimate (rough empirical) ────────────────────────────────────
function _travelTime(distKm, qCfs) {
  var vMs = qCfs > 100000 ? 2.5 : qCfs > 10000 ? 1.8 : qCfs > 1000 ? 1.2 : qCfs > 100 ? 0.7 : 0.4;
  var hrs = (distKm * 1000) / vMs / 3600;
  if (hrs < 1) return Math.round(hrs*60)+' min';
  if (hrs < 24) return hrs.toFixed(1)+' hr';
  return (hrs/24).toFixed(1)+' days';
}

// ── Flood stage pill ──────────────────────────────────────────────────────────
function _floodPill(cls) {
  var map = {
    normal:   ['#334155','#64748b','NORMAL'],
    action:   ['rgba(250,204,21,0.18)','#facc15','ACTION'],
    watch:    ['rgba(251,191,36,0.18)','#fbbf24','WATCH'],
    flood:    ['rgba(251,146,60,0.18)','#fb923c','FLOOD'],
    moderate: ['rgba(248,113,113,0.18)','#f87171','MODERATE'],
    major:    ['rgba(239,68,68,0.18)','#ef4444','MAJOR FLOOD'],
    record:   ['rgba(167,139,250,0.22)','#a78bfa','RECORD'],
  };
  var c = map[cls] || map.normal;
  return '<span class="so-badge" style="background:'+c[0]+';color:'+c[1]+';">'+c[2]+'</span>';
}

// ── Main openSlideover ────────────────────────────────────────────────────────
function openSlideover(siteId) {
  var sel      = _selectedSites.find(function(s){ return s.site_id === siteId; });
  var full     = SITES.find(function(s){ return s.site_id === siteId; }) || {};
  var readings = _readings[siteId] || [];
  var siteType = (full.type || 'river').toLowerCase();
  var isDam    = siteType === 'dam';
  var isRes    = siteType === 'reservoir';
  var accent   = isDam ? '#f97316' : isRes ? '#06b6d4' : (sel ? sel.color : '#0ea5e9');
  var typeLabel= isDam ? 'DAM' : isRes ? 'RESERVOIR' : 'RIVER';
  var typeBg   = isDam ? 'rgba(249,115,22,0.18)' : isRes ? 'rgba(6,182,212,0.18)' : 'rgba(14,165,233,0.18)';

  var panel  = document.getElementById('fn-slideover');
  var iconBg = document.getElementById('so-icon');
  iconBg.style.background = 'rgba('+( isDam?'249,115,22':isRes?'6,182,212':'14,165,233' )+',0.15)';
  iconBg.style.border = '1.5px solid '+accent;
  document.getElementById('so-icon-svg').style.color = accent;
  document.getElementById('so-icon-svg').innerHTML = '<path d="'+(ICON_PATHS_SO[siteType]||ICON_PATHS_SO.river)+'" fill="'+(isRes?accent:'none')+'" fill-opacity="0.3" stroke="'+accent+'" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>';
  document.getElementById('so-site-name').textContent = full.name || siteId;
  document.getElementById('so-site-meta').innerHTML =
    '<span style="font-size:9px;font-weight:700;padding:1px 6px;border-radius:3px;background:'+typeBg+';color:'+accent+';letter-spacing:.07em;">'+typeLabel+'</span>'
    + (full.latitude ? '&nbsp;<span style="color:#334155;">'+full.latitude.toFixed(4)+'°N '+Math.abs(full.longitude).toFixed(4)+'°W</span>' : '')
    + '&nbsp;<span style="color:#334155;">'+(full.source==='cwms'?'CWMS':'USGS')+' '+esc(siteId)+'</span>';
  panel.style.borderLeftColor = accent;

  var incoming = _connections.filter(function(c){ return c.to_site_id   === siteId; });
  var outgoing = _connections.filter(function(c){ return c.from_site_id === siteId; });
  var qR = readings.find(function(r){ return r.param_code==='00060'; });
  var hR = readings.find(function(r){ return r.param_code==='00065'; });

  // ── Section: Current Readings ──────────────────────────────────────────────
  var readHtml = '';
  if (readings.length) {
    readings.forEach(function(r) {
      var ti = r.trend==='rising'?'↑':r.trend==='falling'?'↓':'→';
      var tc = r.trend==='rising'?'#34d399':r.trend==='falling'?'#f87171':'#94a3b8';
      var bg = r.trend==='rising'?'rgba(52,211,153,0.07)':r.trend==='falling'?'rgba(248,113,113,0.07)':'rgba(100,116,139,0.06)';
      readHtml += '<div class="so-reading-row" style="background:'+bg+';border-color:rgba(255,255,255,0.04);">'
        + '<span style="font-size:11px;color:#94a3b8;">'+esc(r.param_name)+'</span>'
        + '<span style="font-size:12px;font-weight:700;color:'+tc+';font-family:JetBrains Mono,monospace;">'
        + r.value.toFixed(2)+' <span style="font-size:9px;font-weight:400;color:#475569;">'+esc(r.unit)+'</span> '+ti+'</span>'
        + '</div>';
    });
  } else {
    readHtml = '<div style="font-size:11px;color:#475569;padding:4px 0;">No readings loaded — select parameters above.</div>';
  }

  // ── Section: Upstream (flows in) ──────────────────────────────────────────
  var upHtml = '';
  if (incoming.length) {
    incoming.forEach(function(c) {
      var fs    = SITES.find(function(s){ return s.site_id === c.from_site_id; }) || {};
      var fSel  = _selectedSites.find(function(s){ return s.site_id === c.from_site_id; });
      var upR   = (_readings[c.from_site_id]||[]).find(function(r){ return r.param_code==='00060'; });
      var fType = (fs.type||'river').toLowerCase();
      var fAcc  = fType==='dam'?'#f97316':fType==='reservoir'?'#06b6d4':(fSel?fSel.color:'#64748b');
      var distKm = haversineKm(fs.latitude, fs.longitude, full.latitude, full.longitude);
      // confluence %: what fraction of this site's discharge comes from upstream?
      var pct = (upR && qR && qR.value) ? Math.round(upR.value/qR.value*100) : null;
      var tt  = (distKm && upR) ? _travelTime(distKm, upR.value) : null;
      upHtml += '<div class="so-conn-row" style="background:rgba(14,165,233,0.05);border-color:rgba(14,165,233,0.14);opacity:'+(fSel?1:0.45)+';">'
        + '<svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="'+fAcc+'" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;"><path d="'+(ICON_PATHS_SO[fType]||ICON_PATHS_SO.river)+'"/></svg>'
        + '<div style="flex:1;min-width:0;">'
        + '<div style="font-size:11px;font-weight:600;color:#cbd5e1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">'+esc(fs.name||c.from_site_id)+'</div>'
        + '<div style="font-size:10px;color:#475569;margin-top:2px;display:flex;flex-wrap:wrap;gap:6px;">'
        + (upR ? '<span>'+upR.value.toFixed(0)+' cfs</span>' : '<span>no data</span>')
        + (distKm ? '<span>'+Math.round(distKm)+' km</span>' : '')
        + (pct !== null ? '<span style="color:#38bdf8;">'+pct+'% of flow</span>' : '')
        + (tt ? '<span style="color:#64748b;">~'+tt+' travel</span>' : '')
        + '</div></div>'
        + '<span style="font-size:20px;color:#38bdf8;opacity:0.7;flex-shrink:0;">↓</span>'
        + '</div>';
    });
  } else {
    upHtml = '<div style="font-size:11px;color:#334155;padding:4px 0;">No upstream connections.</div>';
  }

  // ── Section: Downstream (flows out) ───────────────────────────────────────
  var dnHtml = '';
  if (outgoing.length) {
    outgoing.forEach(function(c) {
      var ts    = SITES.find(function(s){ return s.site_id === c.to_site_id; }) || {};
      var tSel  = _selectedSites.find(function(s){ return s.site_id === c.to_site_id; });
      var dnR   = (_readings[c.to_site_id]||[]).find(function(r){ return r.param_code==='00060'; });
      var tType = (ts.type||'river').toLowerCase();
      var tAcc  = tType==='dam'?'#f97316':tType==='reservoir'?'#06b6d4':(tSel?tSel.color:'#64748b');
      var distKm = haversineKm(full.latitude, full.longitude, ts.latitude, ts.longitude);
      var pct  = (qR && dnR && dnR.value) ? Math.round(qR.value/dnR.value*100) : null;
      var tt   = (distKm && qR) ? _travelTime(distKm, qR.value) : null;
      dnHtml += '<div class="so-conn-row" style="background:rgba(52,211,153,0.05);border-color:rgba(52,211,153,0.14);opacity:'+(tSel?1:0.45)+';">'
        + '<svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="'+tAcc+'" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;"><path d="'+(ICON_PATHS_SO[tType]||ICON_PATHS_SO.river)+'"/></svg>'
        + '<div style="flex:1;min-width:0;">'
        + '<div style="font-size:11px;font-weight:600;color:#cbd5e1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">'+esc(ts.name||c.to_site_id)+'</div>'
        + '<div style="font-size:10px;color:#475569;margin-top:2px;display:flex;flex-wrap:wrap;gap:6px;">'
        + (dnR ? '<span>'+dnR.value.toFixed(0)+' cfs</span>' : '<span>no data</span>')
        + (distKm ? '<span>'+Math.round(distKm)+' km</span>' : '')
        + (pct !== null ? '<span style="color:#34d399;">'+pct+'% of recv flow</span>' : '')
        + (tt ? '<span style="color:#64748b;">~'+tt+' travel</span>' : '')
        + '</div></div>'
        + '<span style="font-size:20px;color:#34d399;opacity:0.7;flex-shrink:0;">↓</span>'
        + '</div>';
    });
  } else {
    dnHtml = '<div style="font-size:11px;color:#334155;padding:4px 0;">No downstream connections.</div>';
  }

  // ── Section: Situation Report (on-demand) ─────────────────────────────────
  var sitrepHtml = '<button class="so-sitrep-btn" onclick="_soLoadSitrep(\''+siteId+'\')" id="so-sitrep-btn">✦ Generate Situation Report</button>'
    + '<div id="so-sitrep-result" style="display:none;margin-top:10px;font-size:11px;color:#cbd5e1;line-height:1.7;"></div>';

  // ── Assemble all sections ──────────────────────────────────────────────────
  var isCwms = full.source === 'cwms';
  var html = ''
    + _soMkSection('readings',   'Current Readings',         null,      readHtml,          true)
    + _soMkSection('trends',     '48-Hour Trends',           '#818cf8', _soLoading(),      true)
    + (isCwms
        ? _soMkSection('resops', 'Reservoir Operations',     '#f59e0b', _soLoading(),      true)
        : _soMkSection('flood',  'Flood Stage Status',       '#fb923c', _soLoading(),      true))
    + _soMkSection('anomaly',    'Anomaly Detection',        '#a78bfa', _soLoading(),      true)
    + _soMkSection('upstream',   'Upstream · Flows In',      '#38bdf8', upHtml,            true)
    + _soMkSection('downstream', 'Downstream · Flows Out',   '#34d399', dnHtml,            true)
    + (!isCwms ? _soMkSection('snotel', 'Upstream Snow (SNOTEL)', '#22d3ee', _soLoading(), false) : '')
    + _soMkSection('sitrep',     'Situation Report',         '#a78bfa', sitrepHtml,        false);

  document.getElementById('so-body').innerHTML = html;
  document.getElementById('fn-slideover-backdrop').style.display = 'block';
  requestAnimationFrame(function(){ panel.style.transform = 'translateX(0)'; });

  // ── Kick off async section loads ──────────────────────────────────────────
  _soLoadTrends(siteId, readings, accent, isCwms);
  if (isCwms) {
    _soLoadReservoirOps(siteId, readings);
  } else {
    _soLoadFloodStages(siteId, hR);
    if (full.latitude) _soLoadSnotel(siteId, full.latitude, full.longitude);
  }
  _soLoadAnomaly(siteId, readings);
}

function closeSlideover() {
  document.getElementById('fn-slideover').style.transform = 'translateX(100%)';
  document.getElementById('fn-slideover-backdrop').style.display = 'none';
}

// ── Async section loaders ──────────────────────────────────────────────────────

// 48-hour sparkline trends
async function _soLoadTrends(siteId, readings, accent, isCwms) {
  var el = document.getElementById('so-sect-trends');
  if (!el) return;
  try {
    var defaultParam = isCwms
      ? { param_code:'Elev-Pool', param_name:'Pool Elevation', unit:'ft' }
      : { param_code:'00060',     param_name:'Discharge',      unit:'cfs' };
    var params = readings.length ? readings : [defaultParam];
    var rows = await Promise.all(params.map(async function(r) {
      var resp = await fetch('/api/data/timeseries?site='+siteId+'&param='+r.param_code+'&hours=48');
      var json = await resp.json();
      return { r: r, data: json.data || [] };
    }));
    var html = '';
    rows.forEach(function(row) {
      if (!row.data.length) return;
      var color = row.r.param_code==='00060' ? accent : '#64748b';
      var vals  = row.data.map(function(d){ return +d.value; }).filter(isFinite);
      var cur   = vals[vals.length-1], mn = Math.min.apply(null,vals), mx = Math.max.apply(null,vals);
      html += '<div class="so-sparkline-row">'
        + '<div style="width:80px;flex-shrink:0;">'
        + '<div style="font-size:9px;color:#475569;text-transform:uppercase;letter-spacing:.06em;">'+esc(row.r.param_name)+'</div>'
        + '<div style="font-size:11px;font-weight:700;color:#e2e8f0;font-family:JetBrains Mono,monospace;margin-top:1px;">'+(cur!=null?cur.toFixed(1):'–')+' <span style="font-size:9px;font-weight:400;color:#475569;">'+esc(row.r.unit||'')+'</span></div>'
        + '<div style="font-size:9px;color:#334155;margin-top:2px;">'+mn.toFixed(0)+'–'+mx.toFixed(0)+'</div>'
        + '</div>'
        + '<div style="flex:1;min-width:0;">'+_sparklineSvg(row.data, color, 200, 36)+'</div>'
        + '</div>';
    });
    el.innerHTML = html || '<div style="font-size:11px;color:#334155;padding:6px 0;">No timeseries data available.</div>';
  } catch(e) {
    if (el) el.innerHTML = '<div style="font-size:11px;color:#475569;">Could not load trends.</div>';
  }
}

// Reservoir operations summary for CWMS dam sites
async function _soLoadReservoirOps(siteId, readings) {
  var el = document.getElementById('so-sect-resops');
  if (!el) return;
  try {
    // Gather relevant CWMS params from current readings
    var pool    = readings.find(function(r){ return r.param_code === 'Elev-Pool' || r.param_code === 'Elev-Forebay'; });
    var tail    = readings.find(function(r){ return r.param_code === 'Elev-Tail'; });
    var outflow = readings.find(function(r){ return r.param_code === 'Flow' || r.param_code === 'Flow-Out'; });
    var inflow  = readings.find(function(r){ return r.param_code === 'Flow-In' || r.param_code === 'Flow-Res In'; });
    var stor    = readings.find(function(r){ return r.param_code === 'Stor' || r.param_code === 'Stor-Conservation Pool'; });
    var pctFull = readings.find(function(r){ return r.param_code.startsWith('%-'); });

    if (!pool && !outflow && !inflow && !stor) {
      el.innerHTML = '<div style="font-size:11px;color:#475569;padding:4px 0;">No CWMS timeseries loaded — select Pool Elev or Outflow parameters above, or add timeseries in the Sites page.</div>';
      return;
    }

    var html = '<div style="display:flex;flex-direction:column;gap:8px;">';

    var rows = [
      pool    && { label: pool.param_name,    val: pool.value,    unit: pool.unit,    trend: pool.trend,    color: '#06b6d4' },
      tail    && { label: tail.param_name,    val: tail.value,    unit: tail.unit,    trend: tail.trend,    color: '#38bdf8' },
      inflow  && { label: inflow.param_name,  val: inflow.value,  unit: inflow.unit,  trend: inflow.trend,  color: '#34d399' },
      outflow && { label: outflow.param_name, val: outflow.value, unit: outflow.unit, trend: outflow.trend, color: '#fb923c' },
      stor    && { label: stor.param_name,    val: stor.value,    unit: stor.unit,    trend: stor.trend,    color: '#a78bfa' },
      pctFull && { label: pctFull.param_name, val: pctFull.value, unit: pctFull.unit, trend: pctFull.trend, color: '#facc15' },
    ].filter(Boolean);

    rows.forEach(function(row) {
      var ti = row.trend==='rising'?'↑':row.trend==='falling'?'↓':'→';
      var tc = row.trend==='rising'?'#34d399':row.trend==='falling'?'#f87171':'#94a3b8';
      var valStr = row.val >= 1000 ? (row.val/1000).toFixed(1)+'k' : row.val.toFixed(1);
      html += '<div style="display:flex;justify-content:space-between;align-items:center;padding:7px 10px;border-radius:7px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.05);">'
        + '<div style="display:flex;align-items:center;gap:7px;">'
        + '<div style="width:3px;height:26px;border-radius:2px;background:'+row.color+';flex-shrink:0;"></div>'
        + '<span style="font-size:11px;color:#94a3b8;">'+esc(row.label)+'</span>'
        + '</div>'
        + '<span style="font-family:JetBrains Mono,monospace;font-size:12px;font-weight:700;color:'+tc+';">'+valStr+' <span style="font-size:9px;font-weight:400;color:#475569;">'+esc(row.unit)+'</span> '+ti+'</span>'
        + '</div>';
    });

    // If pool elev available, show a simple fill indicator (conceptual, no actual capacity data)
    if (pctFull) {
      var pct = Math.min(Math.max(pctFull.value, 0), 100);
      var barColor = pct > 90 ? '#ef4444' : pct > 75 ? '#fb923c' : '#06b6d4';
      html += '<div style="margin-top:4px;">'
        + '<div style="font-size:9px;color:#475569;margin-bottom:4px;text-transform:uppercase;letter-spacing:.06em;">Pool Fill</div>'
        + '<div style="height:8px;border-radius:4px;background:#0f1f35;overflow:hidden;">'
        + '<div style="height:100%;width:'+pct.toFixed(1)+'%;background:'+barColor+';border-radius:4px;transition:width 0.4s;"></div>'
        + '</div>'
        + '<div style="font-size:9px;color:#475569;margin-top:3px;text-align:right;">'+pct.toFixed(1)+'%</div>'
        + '</div>';
    }

    html += '</div>';
    el.innerHTML = html;
  } catch(e) {
    if (el) el.innerHTML = '<div style="font-size:11px;color:#475569;">Could not load reservoir operations.</div>';
  }
}

// Flood stage thresholds from USGS WaterWatch
async function _soLoadFloodStages(siteId, hR) {
  var el = document.getElementById('so-sect-flood');
  if (!el) return;
  try {
    var resp = await fetch('/api/data/flood-stages?sites='+siteId);
    var json = await resp.json();
    var st   = (json.data || {})[siteId];
    if (!st) { el.innerHTML = '<div style="font-size:11px;color:#334155;padding:4px 0;">No stage thresholds on record for this site.</div>'; return; }

    var cur = hR ? hR.value : null;
    var html = '';
    // Status pill
    html += '<div style="display:flex;align-items:center;gap:8px;margin-bottom:10px;">'
      + (cur != null ? '<span style="font-size:12px;font-weight:700;color:#e2e8f0;font-family:JetBrains Mono,monospace;">'+cur.toFixed(2)+' ft</span>' : '')
      + _floodPill(st.class || 'normal')
      + '</div>';

    // Stage bar
    if (cur != null && st.major) {
      var maxVal = Math.max(st.major * 1.15, cur * 1.1);
      var pctCur = Math.min(cur / maxVal * 100, 100);
      var barColor = st.class==='flood'||st.class==='moderate'||st.class==='major' ? '#f87171'
                   : st.class==='action'||st.class==='watch' ? '#facc15' : '#34d399';
      html += '<div class="so-flood-bar">'
        + '<div class="so-stage-pip" style="width:'+pctCur.toFixed(1)+'%;background:'+barColor+';"></div>';
      [['action',st.action,'#facc15'],['flood',st.flood,'#fb923c'],['moderate',st.moderate,'#f87171'],['major',st.major,'#ef4444']].forEach(function(m){
        if (m[1] == null) return;
        var pct = Math.min(m[1]/maxVal*100, 100);
        html += '<div class="so-flood-marker" style="left:'+pct.toFixed(1)+'%;background:'+m[2]+';"></div>';
      });
      html += '</div>';
      html += '<div style="display:flex;gap:12px;margin-top:6px;flex-wrap:wrap;">';
      [['Action',st.action,'#facc15'],['Flood',st.flood,'#fb923c'],['Moderate',st.moderate,'#f87171'],['Major',st.major,'#ef4444']].forEach(function(m){
        if (m[1] == null) return;
        html += '<div style="font-size:9px;color:'+m[2]+';"><span style="color:#334155;">'+m[0]+'</span> '+m[1].toFixed(1)+' ft</div>';
      });
      html += '</div>';
    } else {
      // Just show thresholds as text
      html += '<div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:4px;">';
      [['Action',st.action,'#facc15'],['Flood',st.flood,'#fb923c'],['Moderate',st.moderate,'#f87171'],['Major',st.major,'#ef4444']].forEach(function(m){
        if (m[1] == null) return;
        html += '<div style="font-size:9px;color:'+m[2]+';"><span style="color:#334155;">'+m[0]+'</span> '+m[1].toFixed(1)+' ft</div>';
      });
      if (!hR) html += '<div style="font-size:10px;color:#334155;margin-top:4px;">Add Gage Height param to see live position.</div>';
      html += '</div>';
    }
    el.innerHTML = html;
  } catch(e) {
    if (el) el.innerHTML = '<div style="font-size:11px;color:#475569;">Flood stages unavailable.</div>';
  }
}

// Anomaly detection via z-score on 7-day history
async function _soLoadAnomaly(siteId, readings) {
  var el = document.getElementById('so-sect-anomaly');
  if (!el) return;
  try {
    var html = '';
    var hasAny = false;
    await Promise.all((readings.length ? readings : []).map(async function(r) {
      var resp = await fetch('/api/data/timeseries?site='+siteId+'&param='+r.param_code+'&hours=168');
      var json = await resp.json();
      var hist = json.data || [];
      var score = _anomalyScore(hist, r.value);
      if (!score) return;
      hasAny = true;
      var flag = score.absZ > 3.0 ? 'high' : score.absZ > 2.0 ? 'moderate' : 'normal';
      var fc   = flag==='high' ? '#ef4444' : flag==='moderate' ? '#facc15' : '#34d399';
      var fb   = flag==='high' ? 'rgba(239,68,68,0.1)' : flag==='moderate' ? 'rgba(250,204,21,0.1)' : 'rgba(52,211,153,0.07)';
      var dir  = score.z > 0 ? 'above' : 'below';
      html += '<div style="padding:7px 10px;border-radius:7px;margin-bottom:6px;background:'+fb+';border:1px solid rgba(255,255,255,0.04);">'
        + '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:3px;">'
        + '<span style="font-size:11px;color:#94a3b8;">'+esc(r.param_name)+'</span>'
        + '<span class="so-badge" style="background:'+fb+';color:'+fc+';">'+flag.toUpperCase()+' z='+score.absZ.toFixed(1)+'</span>'
        + '</div>'
        + '<div style="font-size:10px;color:#475569;">'
        + score.absZ.toFixed(1)+'σ '+dir+' 7-day mean of '+score.mean.toFixed(1)+' '+esc(r.unit)+' (n='+score.n+')'
        + '</div>'
        + '</div>';
    }));
    el.innerHTML = hasAny ? html : '<div style="font-size:11px;color:#334155;padding:4px 0;">No readings to analyze.</div>';
  } catch(e) {
    if (el) el.innerHTML = '<div style="font-size:11px;color:#475569;">Anomaly detection unavailable.</div>';
  }
}

// SNOTEL snow water equivalent from NRCS
async function _soLoadSnotel(siteId, lat, lon) {
  var el = document.getElementById('so-sect-snotel');
  if (!el) return;
  try {
    var resp = await fetch('/api/data/snotel?lat='+lat+'&lon='+lon+'&radius=75');
    var json = await resp.json();
    var data = json.data || [];
    if (!data.length) { el.innerHTML = '<div style="font-size:11px;color:#334155;padding:4px 0;">No SNOTEL stations within 75 km.</div>'; return; }
    var html = '';
    data.forEach(function(st) {
      var swe = st.swe_in != null ? st.swe_in.toFixed(1)+' in SWE' : 'no data';
      var sweColor = st.swe_in > 20 ? '#22d3ee' : st.swe_in > 5 ? '#94a3b8' : '#334155';
      html += '<div style="display:flex;align-items:center;justify-content:space-between;padding:6px 10px;border-radius:6px;margin-bottom:4px;background:rgba(34,211,238,0.04);border:1px solid rgba(34,211,238,0.08);">'
        + '<div style="min-width:0;">'
        + '<div style="font-size:11px;color:#cbd5e1;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:220px;">'+esc(st.name)+'</div>'
        + '<div style="font-size:9px;color:#475569;margin-top:1px;">'+(st.elevation ? Math.round(st.elevation)+' ft elev' : '')+(st.date ? ' · '+st.date : '')+'</div>'
        + '</div>'
        + '<div style="font-size:12px;font-weight:700;color:'+sweColor+';font-family:JetBrains Mono,monospace;flex-shrink:0;margin-left:8px;">'+swe+'</div>'
        + '</div>';
    });
    el.innerHTML = html;
  } catch(e) {
    if (el) el.innerHTML = '<div style="font-size:11px;color:#475569;">SNOTEL unavailable.</div>';
  }
}

// Situation report via AI — triggered on button click
async function _soLoadSitrep(siteId) {
  var btn = document.getElementById('so-sitrep-btn');
  var res = document.getElementById('so-sitrep-result');
  if (!btn || !res) return;
  btn.disabled = true;
  btn.textContent = 'Generating…';
  res.style.display = 'none';
  try {
    var site     = SITES.find(function(s){ return s.site_id === siteId; }) || {};
    var readings = _readings[siteId] || [];
    var readingsSummary = readings.map(function(r){
      return r.param_name+': '+r.value.toFixed(2)+' '+r.unit+' ('+r.trend+')';
    }).join(', ');
    var incoming = _connections.filter(function(c){ return c.to_site_id   === siteId; });
    var outgoing = _connections.filter(function(c){ return c.from_site_id === siteId; });
    var query = 'Provide a brief operational situation report for '+(site.name||siteId)
      + ', a '+(site.type||'river')+' gauge in the flow network. '
      + (readingsSummary ? 'Current readings: '+readingsSummary+'. ' : '')
      + (incoming.length ? incoming.length+' upstream source(s). ' : '')
      + (outgoing.length ? outgoing.length+' downstream connection(s). ' : '')
      + 'Include: current flow status, notable trends, any concerns, and recommended monitoring actions. Keep it under 120 words.';
    var resp = await fetch('/api/insights/ask', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ query: query, site_ids: [siteId] })
    });
    var json = await resp.json();
    res.innerHTML = json.response
      ? json.response.replace(/\n/g,'<br>')
      : '<span style="color:#475569;">No response received.</span>';
    res.style.display = 'block';
    btn.textContent = '↺ Regenerate';
    btn.disabled = false;
  } catch(e) {
    res.innerHTML = '<span style="color:#f87171;">Could not generate report: '+esc(e.message)+'</span>';
    res.style.display = 'block';
    btn.textContent = '↺ Retry';
    btn.disabled = false;
  }
}

// ── Auto-analyze (debounced) ──────────────────────────────────────────────────
function scheduleAnalysis() {
  clearTimeout(_analyzeTimer);
  if (_selectedSites.length < 1) { cancelAnalysis(); return; }

  var panel   = document.getElementById('ai-panel');
  var pending = document.getElementById('analysis-pending');
  var bar     = document.getElementById('analysis-progress-bar');

  panel.style.display = 'block';
  if (pending) pending.classList.remove('hidden');

  // Animate progress bar over the delay window
  if (bar) {
    bar.style.transition = 'none';
    bar.style.width = '0%';
    bar.getBoundingClientRect(); // force reflow
    bar.style.transition = 'width ' + (ANALYZE_DELAY/1000) + 's linear';
    bar.style.width = '100%';
  }

  _analyzeTimer = setTimeout(function() {
    if (pending) pending.classList.add('hidden');
    if (bar) { bar.style.transition = 'none'; bar.style.width = '0%'; }
    analyzeNetwork();
  }, ANALYZE_DELAY);
}

function cancelAnalysis() {
  clearTimeout(_analyzeTimer);
  _analyzeTimer = null;
  var pending = document.getElementById('analysis-pending');
  var bar     = document.getElementById('analysis-progress-bar');
  if (pending) pending.classList.add('hidden');
  if (bar) { bar.style.transition = 'none'; bar.style.width = '0%'; }
}

// ── AI Analysis ───────────────────────────────────────────────────────────────
async function analyzeNetwork() {
  var panel   = document.getElementById('ai-panel');
  var loading = document.getElementById('ai-loading');
  var body    = document.getElementById('ai-body');

  panel.style.display = 'block';
  loading.classList.remove('hidden');
  body.style.display = 'none';
  ['ai-summary-wrap','ai-implications-wrap','ai-sitenotes-wrap','ai-rec-wrap','ai-raw'].forEach(function(id) {
    document.getElementById(id).classList.add('hidden');
  });
  document.getElementById('ai-cached').classList.add('hidden');

  var hours = parseInt(document.getElementById('fnHours').value);
  var activeIds = _selectedSites.map(function(s){ return s.site_id; });
  var activeConns = effectiveConnections(activeIds);
  var nodes = _selectedSites.map(function(s){ return { site_id: s.site_id, site_name: s.name, readings: _readings[s.site_id] || [] }; });

  try {
    var resp = await fetch('/api/insights/network', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ nodes: nodes, edges: activeConns, hours: hours })
    });
    var json = await resp.json();
    loading.classList.add('hidden');
    body.style.display = 'block';
    if (json.cached) document.getElementById('ai-cached').classList.remove('hidden');

    var d = json.data || {};
    if (d._raw) {
      document.getElementById('ai-raw').textContent = d._raw;
      document.getElementById('ai-raw').classList.remove('hidden');
      return;
    }

    if (d.network_summary) {
      document.getElementById('ai-summary').textContent = d.network_summary;
      if (d.flow_status) {
        var sc = { normal:'#34d399', elevated:'#fbbf24', flood_risk:'#f87171', drought:'#fb923c', variable:'#94a3b8' };
        document.getElementById('ai-status').innerHTML = '<span style="color:' + (sc[d.flow_status]||'#94a3b8') + ';font-weight:600;text-transform:capitalize;">' + d.flow_status.replace('_',' ') + '</span>';
      }
      document.getElementById('ai-summary-wrap').classList.remove('hidden');
    }

    if (d.implications && d.implications.length) {
      document.getElementById('ai-implications').innerHTML = d.implications.map(function(im) {
        var sc = im.severity ? 'sev-' + im.severity : 'sev-info';
        var cc = im.severity === 'critical' ? 'critical' : im.severity === 'warning' ? 'warning' : im.severity === 'watch' ? 'watch' : '';
        return '<div class="impl-card ' + cc + '">'
          + '<div class="flex items-center gap-2 mb-1">'
          + '<span style="color:#38bdf8;font-size:11px;font-weight:600;">' + esc(im.from_site) + '</span>'
          + '<span style="color:#475569;">→</span>'
          + '<span style="color:#34d399;font-size:11px;font-weight:600;">' + esc(im.to_site) + '</span>'
          + (im.severity ? '<span class="sev-badge ' + sc + ' ml-auto">' + im.severity + '</span>' : '')
          + '</div>'
          + '<div class="text-xs text-slate-300 leading-relaxed">' + esc(im.finding) + '</div>'
          + (im.lag_estimate ? '<div class="text-xs text-slate-600 mt-1">Signal lag: ' + esc(im.lag_estimate) + '</div>' : '')
          + '</div>';
      }).join('');
      document.getElementById('ai-implications-wrap').classList.remove('hidden');
    }

    if (d.site_notes && d.site_notes.length) {
      document.getElementById('ai-sitenotes').innerHTML = d.site_notes.map(function(n) {
        return '<div class="text-xs p-2 rounded" style="background:#0f172a;border:1px solid #1e293b;">'
          + '<span class="font-medium text-slate-300">' + esc(n.site) + ':</span> '
          + '<span class="text-slate-400">' + esc(n.note) + '</span></div>';
      }).join('');
      document.getElementById('ai-sitenotes-wrap').classList.remove('hidden');
    }

    if (d.recommendation) {
      document.getElementById('ai-rec').textContent = d.recommendation;
      document.getElementById('ai-rec-wrap').classList.remove('hidden');
    }

  } catch(e) {
    loading.classList.add('hidden');
    body.style.display = 'block';
    document.getElementById('ai-raw').innerHTML = 'Analysis unavailable. <button onclick="analyzeNetwork()" style="background:none;border:none;cursor:pointer;color:#38bdf8;text-decoration:underline;font-size:inherit;padding:0;">Try again</button>';
    document.getElementById('ai-raw').classList.remove('hidden');
  }
}

// ── NLDI Topology Discovery ───────────────────────────────────────────────────
async function syncTopology() {
  var btn = document.getElementById('syncBtn');
  var status = document.getElementById('sync-status');
  btn.disabled = true;
  btn.querySelector('svg').classList.add('animate-spin');
  status.textContent = 'Querying USGS stream network…';

  try {
    var resp = await fetch('/api/connections/sync', { method: 'POST' });
    var json = await resp.json();
    if (!resp.ok) throw new Error(json.error || 'Discovery failed');
    _connections = json.connections || [];
    var n = json.discovered;
    status.textContent = n
      ? 'Found ' + n + ' connection' + (n !== 1 ? 's' : '') + ' · ' + fmtTime(json.synced_at)
      : 'NLDI returned no connections';
    if (_mapMode) renderMaplibreMap(); else redrawNetwork();
    renderConnections();
  } catch(e) {
    status.textContent = 'Discovery failed — check console';
    console.error('[NLDI sync]', e);
  } finally {
    btn.disabled = false;
    btn.querySelector('svg').classList.remove('animate-spin');
  }
}

// ── Connections sidebar ───────────────────────────────────────────────────────
function renderConnections() {
  var el = document.getElementById('conn-list');
  if (!_connections.length) {
    el.innerHTML = '<span class="text-slate-600 text-xs">Discovering from USGS…</span>';
    return;
  }
  var activeIds = _selectedSites.map(function(s){ return s.site_id; });

  // Direct connections (from DB)
  var rows = _connections.map(function(c) {
    var fSite  = SITES.find(function(s){ return s.site_id === c.from_site_id; });
    var tSite  = SITES.find(function(s){ return s.site_id === c.to_site_id; });
    var active = activeIds.includes(c.from_site_id) && activeIds.includes(c.to_site_id);
    return '<div class="conn-row" style="opacity:' + (active ? '1' : '0.3') + ';display:inline-flex;">'
      + '<span class="conn-from">' + esc(short(fSite ? fSite.name : c.from_site_id)) + '</span>'
      + '<span class="conn-arrow">›</span>'
      + '<span class="conn-to">'   + esc(short(tSite ? tSite.name : c.to_site_id))   + '</span>'
      + '</div>';
  });

  // Bridged connections (effective but not direct) — shown when sites are selected
  if (activeIds.length) {
    effectiveConnections(activeIds).forEach(function(c) {
      if (!c.bridged) return; // skip direct ones already shown above
      var fSite = SITES.find(function(s){ return s.site_id === c.from_site_id; });
      var tSite = SITES.find(function(s){ return s.site_id === c.to_site_id; });
      rows.push('<div class="conn-row" style="opacity:0.85;display:inline-flex;border-color:rgba(249,115,22,0.3);">'
        + '<span class="conn-from" style="color:#fb923c;">' + esc(short(fSite ? fSite.name : c.from_site_id)) + '</span>'
        + '<span class="conn-arrow" title="bridged through unselected sites" style="color:#fb923c;">⤳</span>'
        + '<span class="conn-to"   style="color:#fb923c;">' + esc(short(tSite ? tSite.name : c.to_site_id))   + '</span>'
        + '</div>');
    });
  }

  el.innerHTML = rows.join('');
}

// ── Utilities ─────────────────────────────────────────────────────────────────
function haversineKm(lat1, lon1, lat2, lon2) {
  if (!lat1 || !lon1 || !lat2 || !lon2) return null;
  var R = 6371, dLat = (lat2-lat1)*Math.PI/180, dLon = (lon2-lon1)*Math.PI/180;
  var a = Math.sin(dLat/2)**2 + Math.cos(lat1*Math.PI/180)*Math.cos(lat2*Math.PI/180)*Math.sin(dLon/2)**2;
  return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
}
function truncate(str, n) { return str.length > n ? str.slice(0, n-1)+'…' : str; }
function short(name) {
  return name.replace(/^(.*?)\s+(River|Creek|Run|Brook)\s+/i, function(m, p1, p2) {
    return p1.split(' ').slice(-1)[0] + ' ' + p2 + ' ';
  }).slice(0, 28);
}
function esc(str) {
  if (!str) return '';
  return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
function fmtTime(iso) {
  if (!iso) return '';
  return new Date(iso).toLocaleTimeString([], { hour:'2-digit', minute:'2-digit' });
}

// ── Init ──────────────────────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', function() {
  _selectedParams = Array.from(document.querySelectorAll('#param-chips .param-chip.active')).map(function(b) {
    return { code: b.dataset.code, name: b.dataset.name, unit: b.dataset.unit };
  });
  renderConnections();
  document.getElementById('fnHours').addEventListener('change', refreshData);

  // Pre-select site from ?site= and auto-include its direct neighbours
  var urlSite = new URLSearchParams(location.search).get('site');
  if (urlSite) {
    // IDs to activate: the target site + its direct upstream/downstream neighbours
    var neighbourIds = INIT_CONNS
      .filter(function(c) { return c.from_site_id === urlSite || c.to_site_id === urlSite; })
      .map(function(c)    { return c.from_site_id === urlSite ? c.to_site_id : c.from_site_id; });
    var idsToActivate = [urlSite].concat(neighbourIds);

    // Activate chips without triggering per-chip refreshData calls
    idsToActivate.forEach(function(id) {
      var chip = document.querySelector('#site-chips .fn-chip[data-id="' + id + '"]');
      if (!chip) return;
      chip.classList.add('active');
      chip.querySelector('.cdot').style.background = chip.dataset.color;
    });

    // Rebuild _selectedSites from newly active chips and fire one refresh
    _selectedSites = Array.from(document.querySelectorAll('#site-chips .fn-chip.active')).map(function(b) {
      return { site_id: b.dataset.id, name: b.dataset.name, color: b.dataset.color, source: b.dataset.source };
    });
    document.getElementById('site-count').textContent = _selectedSites.length + ' selected';
    if (_selectedSites.length) refreshData();
  }

  // Resize: redraw so nodes reposition to new canvas dimensions
  var _resizeTimer = null;
  window.addEventListener('resize', function() {
    clearTimeout(_resizeTimer);
    _resizeTimer = setTimeout(function() {
      if (_mapMode && _mlMap) _mlMap.resize();
      else if (_d3Nodes.length) redrawNetwork();
    }, 150);
  });

  fetch('/api/connections/sync-status')
    .then(function(r){ return r.json(); })
    .then(function(json) {
      var status = document.getElementById('sync-status');
      if (json.count > 0 && json.synced_at) {
        var ageH = (Date.now() - new Date(json.synced_at).getTime()) / 3600000;
        if (ageH < STALE_HOURS) {
          status.textContent = json.count + ' connection' + (json.count !== 1 ? 's' : '') + ' · synced ' + fmtTime(json.synced_at);
          return;
        }
      }
      status.textContent = 'Discovering topology…';
      syncTopology();
    })
    .catch(function() { syncTopology(); });
});
</script>


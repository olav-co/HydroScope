<%- include('partials/head', { title: 'AI Chat' }) %>
<%- include('partials/nav') %>

<style>
.msg-user {
  align-self: flex-end;
  max-width: 72%;
  background: rgba(3,105,161,0.25);
  border: 1px solid rgba(14,165,233,0.2);
  border-radius: 14px 14px 3px 14px;
  padding: 10px 14px;
  color: #e2e8f0;
  font-size: 13px;
  line-height: 1.55;
  white-space: pre-wrap;
  word-break: break-word;
}
.msg-ai {
  align-self: flex-start;
  max-width: 80%;
  background: rgba(30,41,59,0.7);
  border: 1px solid #1e293b;
  border-radius: 14px 14px 14px 3px;
  padding: 10px 14px;
  color: #cbd5e1;
  font-size: 13px;
  line-height: 1.6;
  white-space: pre-wrap;
  word-break: break-word;
}
.msg-ai .data-tag {
  display: inline-block;
  font-size: 10px;
  padding: 1px 6px;
  border-radius: 4px;
  background: rgba(14,165,233,0.1);
  color: #38bdf8;
  border: 1px solid rgba(14,165,233,0.2);
  margin-bottom: 6px;
}
.msg-blocked {
  align-self: flex-start;
  max-width: 80%;
  background: rgba(248,113,113,0.06);
  border: 1px solid rgba(248,113,113,0.2);
  border-radius: 14px 14px 14px 3px;
  padding: 8px 14px;
  color: #f87171;
  font-size: 12px;
}
.msg-blocked .blocked-tag {
  display: inline-block;
  font-size: 10px;
  padding: 1px 6px;
  border-radius: 4px;
  background: rgba(248,113,113,0.12);
  color: #f87171;
  border: 1px solid rgba(248,113,113,0.25);
  margin-right: 6px;
  font-weight: 600;
  letter-spacing: .03em;
}
body.light .msg-blocked { background: rgba(248,113,113,0.04); color: #dc2626; }
.msg-time {
  font-size: 10px;
  color: #475569;
  margin-top: 3px;
  padding: 0 4px;
}
.msg-user + .msg-time { text-align: right; }
.typing-dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: #38bdf8; display: inline-block;
  animation: blink 1.2s infinite;
}
.typing-dot:nth-child(2) { animation-delay: .2s; }
.typing-dot:nth-child(3) { animation-delay: .4s; }
@keyframes blink { 0%,80%,100%{opacity:.2} 40%{opacity:1} }
body.light .msg-user { background: rgba(14,165,233,0.12); border-color: rgba(14,165,233,0.3); color: #0f172a; }
body.light .msg-ai   { background: #f8fafc; border-color: #e2e8f0; color: #334155; }
</style>

<main class="flex-1 flex flex-col overflow-hidden">
  <header class="flex items-center justify-between px-6 py-4 border-b border-slate-800" style="background:rgba(15,23,42,0.6);">
    <div>
      <h1 class="text-lg font-semibold text-white">AI Chat</h1>
      <p class="text-xs text-slate-400 mt-0.5">
        <a href="/profile" class="text-hydro-400 hover:underline capitalize"><%= profile?.role?.replace('_',' ') || 'general' %> profile</a>
        · asks about current data are detected automatically
      </p>
    </div>
    <button onclick="clearThread()" class="btn-secondary text-xs py-1 px-3">Clear thread</button>
  </header>

  <div class="flex-1 flex gap-0 overflow-hidden">

    <!-- Chat column -->
    <div class="flex-1 flex flex-col overflow-hidden">

      <!-- Message thread -->
      <div id="thread" class="flex-1 overflow-y-auto px-6 py-4 flex flex-col gap-2">
        <!-- Welcome -->
        <div class="msg-ai" id="welcomeMsg">
          Hey — ask me anything about your monitored sites and current conditions, or just chat. I'll pull in live readings when you mention flows, sites, or parameters.
        </div>
      </div>

      <!-- Typing indicator (hidden) -->
      <div id="typingRow" class="px-6 pb-2" style="display:none;">
        <div class="msg-ai" style="padding:10px 14px;display:inline-flex;align-items:center;gap:4px;">
          <span class="typing-dot"></span><span class="typing-dot"></span><span class="typing-dot"></span>
        </div>
      </div>

      <!-- Input bar -->
      <div class="px-6 pb-5 pt-2">
        <!-- Quick prompts -->
        <div class="flex flex-wrap gap-1.5 mb-3" id="quickPrompts">
          <button class="text-xs px-2.5 py-1 rounded-full border border-slate-700 text-slate-400 hover:border-hydro-600 hover:text-hydro-300 transition-colors" onclick="send('What are current flow conditions across all sites?')">Current flows</button>
          <button class="text-xs px-2.5 py-1 rounded-full border border-slate-700 text-slate-400 hover:border-hydro-600 hover:text-hydro-300 transition-colors" onclick="send('Any anomalies or unusual readings right now?')">Anomalies</button>
          <button class="text-xs px-2.5 py-1 rounded-full border border-slate-700 text-slate-400 hover:border-hydro-600 hover:text-hydro-300 transition-colors" onclick="send('Is it safe for water recreation at any of the monitored sites this weekend?')">Recreation safety</button>
          <button class="text-xs px-2.5 py-1 rounded-full border border-slate-700 text-slate-400 hover:border-hydro-600 hover:text-hydro-300 transition-colors" onclick="send('What\\'s the upstream precipitation looking like?')">Upstream precip</button>
          <button class="text-xs px-2.5 py-1 rounded-full border border-slate-700 text-slate-400 hover:border-hydro-600 hover:text-hydro-300 transition-colors" onclick="send('Any compliance or threshold concerns?')">Compliance</button>
        </div>

        <div class="flex gap-2 items-end">
          <textarea id="chatInput" rows="2"
            class="input flex-1 resize-none"
            style="border-radius:12px;padding:10px 14px;font-size:13px;"
            placeholder="Ask anything... (Enter to send, Shift+Enter for new line)"></textarea>
          <button onclick="sendFromInput()" id="sendBtn"
            class="btn-primary flex-shrink-0 h-10 px-4 rounded-xl">Send</button>
        </div>
      </div>
    </div>

    <!-- Recent sidebar -->
    <div class="w-64 flex-shrink-0 border-l border-slate-800 flex flex-col overflow-hidden" style="background:rgba(15,23,42,0.4);">
      <div class="px-4 py-3 border-b border-slate-800">
        <div class="text-xs font-medium text-slate-500 uppercase tracking-wider">Recent</div>
      </div>
      <div class="flex-1 overflow-y-auto px-3 py-3 flex flex-col gap-2">
        <% if (!recentInsights.length) { %>
          <div class="text-xs text-slate-600 text-center py-6">No history yet.</div>
        <% } %>
        <% for (const ins of recentInsights) { %>
        <div class="rounded-lg p-2.5 cursor-pointer border border-transparent hover:border-slate-700 transition-colors"
          style="background:rgba(30,41,59,0.5);"
          onclick="replaySaved(<%- JSON.stringify(ins.prompt) %>, <%- JSON.stringify(ins.response) %>)">
          <div class="text-xs text-slate-300 line-clamp-2 mb-1"><%= ins.prompt %></div>
          <div class="text-xs text-slate-600"><%= new Date(ins.created_at).toLocaleDateString() %> · <%= ins.profile_role || 'general' %></div>
        </div>
        <% } %>
      </div>
    </div>

  </div>
</main>

<script>
var history = []; // [{role:'user'|'model', text:'...'}]

function now() {
  return new Date().toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });
}

function appendMsg(role, text, dataIncluded) {
  var thread = document.getElementById('thread');

  var div = document.createElement('div');
  div.className = role === 'user' ? 'msg-user' : 'msg-ai';

  if (role === 'model' && dataIncluded) {
    div.innerHTML = '<span class="data-tag">live data</span>\n' + escHtml(text);
  } else {
    div.textContent = text;
  }
  thread.appendChild(div);

  var time = document.createElement('div');
  time.className = 'msg-time';
  time.textContent = now();
  if (role === 'user') time.style.textAlign = 'right';
  thread.appendChild(time);

  thread.scrollTop = thread.scrollHeight;
}

function appendBlocked() {
  var thread = document.getElementById('thread');
  var div = document.createElement('div');
  div.className = 'msg-blocked';
  div.innerHTML = '<span class="blocked-tag">BLOCKED</span>That\'s outside what I can help with here. I\'m scoped to hydrology, water monitoring, and your configured sites.';
  thread.appendChild(div);

  var time = document.createElement('div');
  time.className = 'msg-time';
  time.textContent = now();
  thread.appendChild(time);

  thread.scrollTop = thread.scrollHeight;
}

function appendError() {
  var thread = document.getElementById('thread');
  var div = document.createElement('div');
  div.className = 'msg-ai';
  div.style.color = '#94a3b8';
  div.textContent = 'Something went wrong. Please try again.';
  thread.appendChild(div);
  thread.scrollTop = thread.scrollHeight;
}

function escHtml(s) {
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

function setTyping(on) {
  document.getElementById('typingRow').style.display = on ? 'block' : 'none';
  document.getElementById('thread').scrollTop = document.getElementById('thread').scrollHeight;
}

async function send(text) {
  text = text.trim();
  if (!text) return;

  // Hide welcome message after first send
  var welcome = document.getElementById('welcomeMsg');
  if (welcome) { welcome.remove(); }

  appendMsg('user', text);
  history.push({ role: 'user', text: text });

  document.getElementById('chatInput').value = '';
  document.getElementById('sendBtn').disabled = true;
  setTyping(true);

  try {
    var resp = await fetch('/api/insights/chat', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ history: history.slice(0, -1), query: text })
    });
    var json = await resp.json();
    setTyping(false);

    if (json.blocked) {
      // Remove the user message from history — blocked turns don't count
      history.pop();
      appendBlocked();
    } else if (!json.ok || json.error) {
      history.pop();
      appendError();
    } else {
      appendMsg('model', json.response, json.dataIncluded);
      history.push({ role: 'model', text: json.response });
    }
  } catch (e) {
    setTyping(false);
    history.pop();
    appendError();
  }

  document.getElementById('sendBtn').disabled = false;
  document.getElementById('chatInput').focus();
}

function sendFromInput() {
  send(document.getElementById('chatInput').value);
}

function clearThread() {
  history = [];
  var thread = document.getElementById('thread');
  thread.innerHTML = '';
  var welcome = document.createElement('div');
  welcome.id = 'welcomeMsg';
  welcome.className = 'msg-ai';
  welcome.textContent = 'Thread cleared. Ask me anything.';
  thread.appendChild(welcome);
}

function replaySaved(prompt, response) {
  var thread = document.getElementById('thread');
  var welcome = document.getElementById('welcomeMsg');
  if (welcome) welcome.remove();

  history = [
    { role: 'user',  text: prompt },
    { role: 'model', text: response },
  ];
  thread.innerHTML = '';
  appendMsg('user',  prompt,   false);
  appendMsg('model', response, false);
}

document.getElementById('chatInput').addEventListener('keydown', function(e) {
  if (e.key === 'Enter' && !e.shiftKey) {
    e.preventDefault();
    sendFromInput();
  }
});

window.addEventListener('hydroProfileUpdated', function() {
  var thread = document.getElementById('thread');
  var notice = document.createElement('div');
  notice.style.cssText = 'text-align:center;font-size:11px;color:#475569;padding:6px 0;font-style:italic;';
  notice.textContent = 'Profile updated — AI context refreshed for next message';
  thread.appendChild(notice);
  thread.scrollTop = thread.scrollHeight;
});
</script>

<%- include('partials/foot') %>

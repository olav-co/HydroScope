<%- include('partials/head', { title: 'AI Insights' }) %>
<%- include('partials/nav') %>

<main class="flex-1 flex flex-col overflow-hidden">
  <header class="flex items-center justify-between px-6 py-4 border-b border-slate-800 bg-slate-900/50">
    <div>
      <h1 class="text-lg font-semibold text-white">AI Insights</h1>
      <p class="text-xs text-slate-400 mt-0.5">
        Ask questions — responses are tailored to your
        <a href="/profile" class="text-hydro-400 hover:underline"><%= profile?.role?.replace('_',' ') || 'general' %> profile</a>
      </p>
    </div>
  </header>

  <div class="flex-1 overflow-hidden flex gap-6 p-6">

    <!-- Ask panel -->
    <div class="flex-1 flex flex-col gap-4 min-w-0">

      <!-- Query form -->
      <div class="card">
        <label class="label mb-2">Your Question or Analysis Request</label>
        <textarea id="queryInput" rows="3" class="input resize-none mb-3"
          placeholder="e.g. 'Is it safe to kayak the Willamette this weekend?' or 'Summarize any flow anomalies across all sites.'"></textarea>
        <div class="flex flex-wrap items-center gap-3">
          <div class="flex-1 min-w-48">
            <label class="label text-xs">Scope to specific sites (optional)</label>
            <select id="insightSites" class="input text-xs" multiple size="3">
              <option value="" selected>(All sites)</option>
              <% for (const s of sites) { %>
                <option value="<%= s.site_id %>"><%= s.name %></option>
              <% } %>
            </select>
          </div>
          <div class="flex flex-col gap-2">
            <label class="flex items-center gap-2 text-xs text-slate-400 cursor-pointer">
              <input type="checkbox" id="bypassCache" class="accent-hydro-500"> Skip cache (fresh response)
            </label>
            <button onclick="askInsight()" class="btn-primary">Ask Gemini</button>
          </div>
        </div>
      </div>

      <!-- Response -->
      <div id="responseCard" class="card hidden flex-1">
        <div class="flex items-center gap-2 mb-3">
          <div class="w-6 h-6 rounded bg-hydro-700 flex items-center justify-center text-xs font-bold text-white">AI</div>
          <span class="text-xs text-slate-400" id="responseMetaLine"></span>
        </div>
        <div id="responseBody" class="text-sm text-slate-200 leading-relaxed whitespace-pre-wrap max-h-96 overflow-y-auto pr-1"></div>
      </div>

      <div id="responseLoading" class="hidden card flex items-center gap-3 text-slate-400 py-8 justify-center">
        <svg class="animate-spin w-5 h-5 text-hydro-500" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/>
        </svg>
        Generating insight with Gemini...
      </div>

      <!-- Quick prompts -->
      <div class="card">
        <div class="text-xs text-slate-400 mb-3 font-medium">Quick Prompts</div>
        <div class="flex flex-wrap gap-2">
          <button class="quick-prompt" onclick="setPrompt('Give me a summary of current conditions across all monitored sites.')">Current conditions summary</button>
          <button class="quick-prompt" onclick="setPrompt('Are there any unusual readings or anomalies in the recent data?')">Anomaly check</button>
          <button class="quick-prompt" onclick="setPrompt('What are the water quality indicators telling us right now?')">Water quality</button>
          <button class="quick-prompt" onclick="setPrompt('Compare the current flows to what is typical for this time of year.')">Seasonal context</button>
          <button class="quick-prompt" onclick="setPrompt('What should I know before visiting the Willamette River this week?')">Visitor advisory</button>
          <button class="quick-prompt" onclick="setPrompt('Identify any compliance or threshold concerns in the current data.')">Compliance check</button>
        </div>
      </div>
    </div>

    <!-- Recent insights sidebar -->
    <div class="w-72 flex-shrink-0 flex flex-col gap-3">
      <div class="text-xs font-medium text-slate-400 uppercase tracking-widest px-1">Recent Insights</div>
      <% if (recentInsights.length === 0) { %>
        <div class="card text-xs text-slate-600 text-center py-6">No insights yet. Ask your first question.</div>
      <% } %>
      <% for (const ins of recentInsights) { %>
      <div class="card cursor-pointer hover:border-hydro-700 transition-colors" onclick="showSavedInsight(<%- JSON.stringify(ins.prompt.replace(/'/g,'\\\'')) %>, <%- JSON.stringify(ins.response.replace(/'/g,'\\\'')) %>, '<%- ins.profile_role %>')">
        <div class="text-xs text-hydro-400 mb-1 capitalize"><%= ins.profile_role?.replace('_',' ') || 'general' %></div>
        <div class="text-xs text-slate-300 line-clamp-2"><%= ins.prompt %></div>
        <div class="text-xs text-slate-600 mt-1"><%= new Date(ins.created_at).toLocaleDateString() %></div>
      </div>
      <% } %>
    </div>

  </div>
</main>

<script>
async function askInsight() {
  const query = document.getElementById('queryInput').value.trim();
  if (!query) return;

  const siteSelect = document.getElementById('insightSites');
  const selectedSites = Array.from(siteSelect.selectedOptions)
    .map(o => o.value).filter(v => v !== '');
  const bypassCache = document.getElementById('bypassCache').checked;

  document.getElementById('responseCard').classList.add('hidden');
  document.getElementById('responseLoading').classList.remove('hidden');

  try {
    const resp = await fetch('/api/insights/ask', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ query, site_ids: selectedSites, bypass_cache: bypassCache })
    });
    const json = await resp.json();

    document.getElementById('responseLoading').classList.add('hidden');
    document.getElementById('responseCard').classList.remove('hidden');
    document.getElementById('responseBody').textContent = json.response || json.error || 'No response.';
    document.getElementById('responseMetaLine').textContent =
      (json.cached ? 'Cached response' : 'Fresh response') +
      (selectedSites.length ? ` · ${selectedSites.length} site(s) scoped` : ' · All sites');
  } catch (err) {
    document.getElementById('responseLoading').classList.add('hidden');
    document.getElementById('responseCard').classList.remove('hidden');
    document.getElementById('responseBody').textContent = 'Error: ' + err.message;
  }
}

function setPrompt(text) {
  document.getElementById('queryInput').value = text;
  document.getElementById('queryInput').focus();
}

function showSavedInsight(prompt, response, role) {
  document.getElementById('queryInput').value = prompt;
  document.getElementById('responseBody').textContent = response;
  document.getElementById('responseMetaLine').textContent = `Saved · ${role || 'general'} profile`;
  document.getElementById('responseCard').classList.remove('hidden');
}

document.getElementById('queryInput').addEventListener('keydown', e => {
  if (e.key === 'Enter' && (e.ctrlKey || e.metaKey)) askInsight();
});
</script>

<%- include('partials/foot') %>
